--// CYBER-EXECUTIVE HUB (MOBILE OPTIMIZED) //--

--// SERVICES
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local player = Players.LocalPlayer

--// VARIABLES
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "CyberExecHub"
ScreenGui.Parent = game.CoreGui
ScreenGui.DisplayOrder = 100
ScreenGui.IgnoreGuiInset = true

local existingButtons = {}
local currentTab = "Search"

--// COLORS
local BG = Color3.fromRGB(10,10,10)
local ACCENT = Color3.fromRGB(138,43,226)

--// MAIN FRAME
local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 320, 0, 400)
MainFrame.Position = UDim2.new(0.5, -160, 0.5, -200)
MainFrame.BackgroundColor3 = BG
MainFrame.ZIndex = 1
MainFrame.Parent = ScreenGui

--// DRAGGING
local dragging, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = MainFrame.Position
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
		local delta = input.Position - dragStart
		MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

--// SIDEBAR
local Sidebar = Instance.new("Frame")
Sidebar.Size = UDim2.new(0, 80, 1, 0)
Sidebar.BackgroundColor3 = BG
Sidebar.ZIndex = 5
Sidebar.Parent = MainFrame

local function createTabButton(name, pos)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1,0,0,40)
	btn.Position = UDim2.new(0,0,0,pos)
	btn.Text = name
	btn.BackgroundColor3 = BG
	btn.TextColor3 = ACCENT
	btn.ZIndex = 20
	btn.Parent = Sidebar
	
	btn.MouseButton1Click:Connect(function()
		currentTab = name
		for _,frame in pairs(MainFrame:GetChildren()) do
			if frame:IsA("Frame") and frame.Name == "TabFrame" then
				frame.Visible = (frame.Tag.Value == name)
			end
		end
	end)
end

createTabButton("Search", 0)
createTabButton("Manage", 50)
createTabButton("Files", 100)

--// TAB CREATOR
local function createTab(name)
	local frame = Instance.new("Frame")
	frame.Name = "TabFrame"
	frame.Size = UDim2.new(1,-80,1,0)
	frame.Position = UDim2.new(0,80,0,0)
	frame.BackgroundTransparency = 1
	frame.ZIndex = 10
	frame.Visible = (name == "Search")
	frame.Parent = MainFrame
	
	local tag = Instance.new("StringValue")
	tag.Name = "Tag"
	tag.Value = name
	tag.Parent = frame
	
	return frame
end

--// SEARCH TAB
local SearchTab = createTab("Search")

local searchBox = Instance.new("TextBox")
searchBox.Size = UDim2.new(1,-20,0,40)
searchBox.Position = UDim2.new(0,10,0,10)
searchBox.PlaceholderText = "Enter file name..."
searchBox.BackgroundColor3 = BG
searchBox.TextColor3 = ACCENT
searchBox.ZIndex = 20
searchBox.Parent = SearchTab

searchBox.FocusLost:Connect(function(enter)
	if enter then
		local path = "My_Script_Hub/"..searchBox.Text..".lua"
		if isfile(path) then
			loadstring(readfile(path))()
		end
	end
end)

--// MANAGE TAB
local ManageTab = createTab("Manage")

local deleteBox = Instance.new("TextBox")
deleteBox.Size = UDim2.new(1,-20,0,40)
deleteBox.Position = UDim2.new(0,10,0,10)
deleteBox.PlaceholderText = "File to delete..."
deleteBox.BackgroundColor3 = BG
deleteBox.TextColor3 = ACCENT
deleteBox.ZIndex = 20
deleteBox.Parent = ManageTab

local deleteBtn = Instance.new("TextButton")
deleteBtn.Size = UDim2.new(1,-20,0,40)
deleteBtn.Position = UDim2.new(0,10,0,60)
deleteBtn.Text = "Delete"
deleteBtn.BackgroundColor3 = BG
deleteBtn.TextColor3 = ACCENT
deleteBtn.ZIndex = 20
deleteBtn.Parent = ManageTab

--// CONFIRMATION PROMPT
local ConfirmFrame = Instance.new("Frame")
ConfirmFrame.Size = UDim2.new(0,250,0,120)
ConfirmFrame.Position = UDim2.new(0.5,-125,0.5,-60)
ConfirmFrame.BackgroundColor3 = BG
ConfirmFrame.Visible = false
ConfirmFrame.ZIndex = 50
ConfirmFrame.Parent = ScreenGui

local confirmText = Instance.new("TextLabel")
confirmText.Size = UDim2.new(1,0,0,60)
confirmText.Text = "Are you sure?"
confirmText.TextColor3 = ACCENT
confirmText.BackgroundTransparency = 1
confirmText.ZIndex = 50
confirmText.Parent = ConfirmFrame

local yesBtn = Instance.new("TextButton")
yesBtn.Size = UDim2.new(0.5,0,0,40)
yesBtn.Position = UDim2.new(0,0,1,-40)
yesBtn.Text = "Yes"
yesBtn.BackgroundColor3 = BG
yesBtn.TextColor3 = ACCENT
yesBtn.ZIndex = 50
yesBtn.Parent = ConfirmFrame

local noBtn = Instance.new("TextButton")
noBtn.Size = UDim2.new(0.5,0,0,40)
noBtn.Position = UDim2.new(0.5,0,1,-40)
noBtn.Text = "No"
noBtn.BackgroundColor3 = BG
noBtn.TextColor3 = ACCENT
noBtn.ZIndex = 50
noBtn.Parent = ConfirmFrame

local fileToDelete = nil

deleteBtn.MouseButton1Click:Connect(function()
	fileToDelete = "My_Script_Hub/"..deleteBox.Text..".lua"
	if isfile(fileToDelete) then
		ConfirmFrame.Visible = true
	end
end)

yesBtn.MouseButton1Click:Connect(function()
	if fileToDelete then
		delfile(fileToDelete)
	end
	ConfirmFrame.Visible = false
end)

noBtn.MouseButton1Click:Connect(function()
	ConfirmFrame.Visible = false
end)

--// FILES TAB
local FilesTab = createTab("Files")

local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1,0,1,0)
scroll.CanvasSize = UDim2.new(0,0,0,0)
scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
scroll.BackgroundTransparency = 1
scroll.ZIndex = 10
scroll.Parent = FilesTab

local layout = Instance.new("UIListLayout")
layout.Parent = scroll

local function UpdateFiles()
	for _,btn in pairs(existingButtons) do
		btn:Destroy()
	end
	existingButtons = {}
	
	if isfolder("My_Script_Hub") then
		for _,file in pairs(listfiles("My_Script_Hub/")) do
			local name = file:match("([^/]+)%.lua$")
			if name then
				local btn = Instance.new("TextButton")
				btn.Size = UDim2.new(1,0,0,40)
				btn.Text = name
				btn.BackgroundColor3 = BG
				btn.TextColor3 = ACCENT
				btn.ZIndex = 20
				btn.Parent = scroll
				
				btn.MouseButton1Click:Connect(function()
					loadstring(readfile(file))()
				end)
				
				table.insert(existingButtons, btn)
			end
		end
	end
end

UpdateFiles()

--// FLOATING TOGGLE BUTTON
local Toggle = Instance.new("TextButton")
Toggle.Size = UDim2.new(0,50,0,50)
Toggle.Position = UDim2.new(0,10,0.5,-25)
Toggle.Text = "S"
Toggle.BackgroundColor3 = ACCENT
Toggle.TextColor3 = Color3.new(1,1,1)
Toggle.ZIndex = 1000
Toggle.Parent = ScreenGui

Toggle.MouseButton1Click:Connect(function()
	MainFrame.Visible = not MainFrame.Visible
end)
