-- MANAGE PAGE
--////////////////////////////////////////////////////
local ManageWrap = make("Frame", {
    BackgroundTransparency = 1,
    Size = UDim2.new(1, 0, 1, 0),
    ZIndex = 10
}, ManagePage)

local ManageTitle = label(ManageWrap, "Create or overwrite a script file.", 13, C.MUTED, false)
ManageTitle.Size = UDim2.new(1, -4, 0, 18)
ManageTitle.ZIndex = 12

local FileNameBox = input(ManageWrap, "filename.lua", false, 38)
FileNameBox.Position = UDim2.new(0, 0, 0, 24)
FileNameBox.Size = UDim2.new(1, -2, 0, 38)
FileNameBox.ZIndex = 20

local CodeBox = input(ManageWrap, "Paste code here...", true, 126)
CodeBox.Position = UDim2.new(0, 0, 0, 72)
CodeBox.Size = UDim2.new(1, -2, 0, 126)
CodeBox.TextYAlignment = Enum.TextYAlignment.Top
CodeBox.ZIndex = 20

local SaveBtn = button(ManageWrap, "Save / Overwrite", C.ACCENT, Color3.new(1,1,1), 14)
SaveBtn.Position = UDim2.new(0, 0, 0, 208)
SaveBtn.Size = UDim2.new(1, -2, 0, 38)
SaveBtn.ZIndex = 20

local ClearBtn = button(ManageWrap, "Clear Fields", C.SURFACE_2, C.TEXT, 14)
ClearBtn.Position = UDim2.new(0, 0, 0, 254)
ClearBtn.Size = UDim2.new(1, -2, 0, 34)
ClearBtn.ZIndex = 20

SaveBtn.MouseButton1Click:Connect(function()
    local fileName = ensureLuaName(FileNameBox.Text)
    local code = CodeBox.Text or ""

    if fileName == "" then
        showToast("Missing Name", "Enter a filename first.", C.DANGER)
        return
    end

    local path = folderPath .. fileName
    local ok, err = pcall(writefile, path, code)
    if ok then
        showToast("Saved", fileName, C.SUCCESS)
        refreshFiles()
    else
        showToast("Save Failed", tostring(err), C.DANGER)
    end
end)

ClearBtn.MouseButton1Click:Connect(function()
    FileNameBox.Text = ""
    CodeBox.Text = ""
    showToast("Cleared", "Input fields reset.", C.SUCCESS)
end)

--////////////////////////////////////////////////////
-- INITIALIZATION
--////////////////////////////////////////////////////
refreshFiles()
switchPage(SearchPage, "Search")
renderSearchResults("")

showToast("Ready", "Hub loaded successfully.", C.SUCCESS)
