local function RefreshSavedScripts()
    for _, child in pairs(SavedScroll:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    local files = listfiles(MAIN_FOLDER)
    
    if #files == 0 then
        local emptyMsg = Instance.new("TextLabel", SavedScroll)
        emptyMsg.Size = UDim2.new(1, 0, 0, 100)
        emptyMsg.BackgroundTransparency = 1
        emptyMsg.Font = Enum.Font.GothamBold
        emptyMsg.Text = "No saved scripts yet!\n\nUse the Add Script page to save your first script."
        emptyMsg.TextColor3 = Theme.TextDim
        emptyMsg.TextSize = 13
        emptyMsg.TextWrapped = true
        return
    end
    
    for _, filepath in pairs(files) do
        local filename = filepath:gsub(MAIN_FOLDER.."/", "")
        
        local scriptCard = Instance.new("Frame", SavedScroll)
        scriptCard.Size = UDim2.new(1, -8, 0, 70)
        scriptCard.BackgroundColor3 = Theme.Surface
        scriptCard.BorderSizePixel = 0
        
        CreateCorner(scriptCard, 10)
        CreateStroke(scriptCard, Theme.Border, 1, 0.6)
        
        local scriptIcon = Instance.new("ImageLabel", scriptCard)
        scriptIcon.Size = UDim2.new(0, 45, 0, 45)
        scriptIcon.Position = UDim2.new(0, 15, 0.5, -22.5)
        scriptIcon.BackgroundColor3 = Theme.Primary
        scriptIcon.Image = "rbxassetid://6034287594"
        scriptIcon.ImageColor3 = Theme.Text
        scriptIcon.BorderSizePixel = 0
        
        CreateCorner(scriptIcon, 8)
        
        local scriptName = Instance.new("TextLabel", scriptCard)
        scriptName.Size = UDim2.new(0.5, 0, 1, 0)
        scriptName.Position = UDim2.new(0, 70, 0, 0)
        scriptName.BackgroundTransparency = 1
        scriptName.Font = Enum.Font.GothamBold
        scriptName.Text = filename
        scriptName.TextColor3 = Theme.Text
        scriptName.TextSize = 13
        scriptName.TextXAlignment = "Left"
        scriptName.TextTruncate = "AtEnd"
        
        local fileSize = Instance.new("TextLabel", scriptCard)
        fileSize.Size = UDim2.new(0.3, 0, 0.5, 0)
        fileSize.Position = UDim2.new(0, 70, 0.5, 0)
        fileSize.BackgroundTransparency = 1
        fileSize.Font = Enum.Font.Gotham
        local size = #readfile(filepath)
        fileSize.Text = string.format("%.2f KB", size / 1024)
        fileSize.TextColor3 = Theme.TextDim
        fileSize.TextSize = 10
        fileSize.TextXAlignment = "Left"
        
        local runBtn = CreateButton(scriptCard, "▶", function()
            local code = readfile(filepath)
            loadstring(code)()
        end, "Success")
        runBtn.Size = UDim2.new(0, 55, 0, 40)
        runBtn.Position = UDim2.new(1, -130, 0.5, -20)
        runBtn.TextSize = 16
        
        local deleteBtn = CreateButton(scriptCard, "🗑", function()
            local popup = Instance.new("Frame", ScreenGui)
            popup.Size = UDim2.new(0, 320, 0, 170)
            popup.Position = UDim2.new(0.5, -160, 0.5, -85)
            popup.BackgroundColor3 = Theme.Surface
            popup.BorderSizePixel = 0
            popup.ZIndex = 10000
            
            CreateCorner(popup, 12)
            CreateStroke(popup, Theme.Danger, 2, 0.5)
            CreateShadow(popup)
            
            local popupIcon = Instance.new("TextLabel", popup)
            popupIcon.Size = UDim2.new(1, 0, 0, 50)
            popupIcon.BackgroundTransparency = 1
            popupIcon.Font = Enum.Font.GothamBold
            popupIcon.Text = "⚠"
            popupIcon.TextColor3 = Theme.Danger
            popupIcon.TextSize = 35
            
            local popupTitle = Instance.new("TextLabel", popup)
            popupTitle.Size = UDim2.new(1, 0, 0, 30)
            popupTitle.Position = UDim2.new(0, 0, 0, 50)
            popupTitle.BackgroundTransparency = 1
            popupTitle.Font = Enum.Font.GothamBold
            popupTitle.Text = "CONFIRM DELETE"
            popupTitle.TextColor3 = Theme.Danger
            popupTitle.TextSize = 15
            
            local popupText = Instance.new("TextLabel", popup)
            popupText.Size = UDim2.new(1, -30, 0, 40)
            popupText.Position = UDim2.new(0, 15, 0, 80)
            popupText.BackgroundTransparency = 1
            popupText.Font = Enum.Font.Gotham
            popupText.Text = "Delete '" .. filename .. "'?\nThis action cannot be undone."
            popupText.TextColor3 = Theme.Text
            popupText.TextSize = 12
            popupText.TextWrapped = true
            
            local yesBtn = CreateButton(popup, "DELETE", function()
                delfile(filepath)
                popup:Destroy()
                RefreshSavedScripts()
                
                -- Deletion notification
                local delNotif = Instance.new("Frame", ScreenGui)
                delNotif.Size = UDim2.new(0, 250, 0, 60)
                delNotif.Position = UDim2.new(0.5, -125, 0, -70)
                delNotif.BackgroundColor3 = Theme.Danger
                delNotif.BorderSizePixel = 0
                delNotif.ZIndex = 10000
                
                CreateCorner(delNotif, 10)
                
                local delText = Instance.new("TextLabel", delNotif)
                delText.Size = UDim2.new(1, 0, 1, 0)
                delText.BackgroundTransparency = 1
                delText.Text = "🗑 Script Deleted"
                delText.TextColor3 = Color3.new(1,1,1)
                delText.Font = Enum.Font.GothamBold
                delText.TextSize = 14
                
                TweenService:Create(delNotif, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Position = UDim2.new(0.5, -125, 0, 20)}):Play()
                wait(2)
                TweenService:Create(delNotif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -125, 0, -70)}):Play()
                wait(0.3)
                delNotif:Destroy()
            end, "Danger")
            yesBtn.Size = UDim2.new(0.42, 0, 0, 45)
            yesBtn.Position = UDim2.new(0.08, 0, 1, -55)
            yesBtn.TextSize = 13
            
            local noBtn = CreateButton(popup, "CANCEL", function()
                popup:Destroy()
            end, "Secondary")
            noBtn.Size = UDim2.new(0.42, 0, 0, 45)
            noBtn.Position = UDim2.new(0.52, 0, 1, -55)
            noBtn.TextSize = 13
        end, "Danger")
        deleteBtn.Size = UDim2.new(0, 55, 0, 40)
        deleteBtn.Position = UDim2.new(1, -65, 0.5, -20)
        deleteBtn.TextSize = 16
    end
end

