CodeEditor:GetPropertyChangedSignal("Text"):Connect(function()
    local lines = {}
    for line in CodeEditor.Text:gmatch("[^\n]+") do
        table.insert(lines, line)
    end
    
    local lineCount = #lines
    local numberText = ""
    for i = 1, math.max(lineCount, 10) do
        numberText = numberText .. i .. "\n"
    end
    LineNumbersText.Text = numberText
end)

