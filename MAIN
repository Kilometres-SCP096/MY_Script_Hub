PagesContainer.Position = UDim2.new(0, 140, 0, 45)
PagesContainer.BackgroundTransparency = 1
PagesContainer.Parent = MainFrame

-- // CREATE PAGE FUNCTION // --
local currentPage = nil

local function CreatePage(pageName)
    -- Create Page
    local Page = Instance.new("ScrollingFrame")
    Page.Name = pageName .. "Page"
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.BorderSizePixel = 0
    Page.ScrollBarThickness = 4
    Page.ScrollBarImageColor3 = Color3.fromRGB(138, 43, 226)
    Page.CanvasSize = UDim2.new(0, 0, 0, 0)
    Page.AutomaticCanvasSize = Enum.AutomaticCanvasSize.Y
    Page.Visible = false
    Page.Parent = PagesContainer
    
    local PageLayout = Instance.new("UIListLayout")
    PageLayout.Padding = UDim.new(0, 10)
    PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
    PageLayout.Parent = Page
    
    local PagePadding = Instance.new("UIPadding")
    PagePadding.PaddingTop = UDim.new(0, 5)
    PagePadding.PaddingLeft = UDim.new(0, 5)
    PagePadding.PaddingRight = UDim.new(0, 10)
    PagePadding.Parent = Page
    
    -- Create Tab Button
    local TabButton = Instance.new("TextButton")
    TabButton.Name = pageName .. "Tab"
    TabButton.Size = UDim2.new(1, 0, 0, 40)
    TabButton.Text = pageName
    TabButton.TextColor3 = Color3.fromRGB(200, 200, 200)
    TabButton.Font = Enum.Font.Gotham
    TabButton.TextSize = 14
    TabButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    TabButton.BorderSizePixel = 0
    TabButton.Parent = Sidebar
    
    local TabCorner = Instance.new("UICorner")
    TabCorner.CornerRadius = UDim.new(0, 6)
    TabCorner.Parent = TabButton
    
    TabButton.MouseButton1Click:Connect(function()
        -- Hide all pages
        for _, child in pairs(PagesContainer:GetChildren()) do
            if child:IsA("ScrollingFrame") then
                child.Visible = false
            end
        end
        -- Show this page
        Page.Visible = true
        currentPage = Page
        
        -- Update tab colors
        for _, tab in pairs(Sidebar:GetChildren()) do
            if tab:IsA("TextButton") then
                tab.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                tab.TextColor3 = Color3.fromRGB(200, 200, 200)
            end
        end
        TabButton.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
        TabButton.TextColor3 = Color3.new(1, 1, 1)
    end)
    
    return Page
end

-- // CREATE PAGES // --
local SearchPage = CreatePage("Search")
local ManagePage = CreatePage("Manage")
local FilesPage = CreatePage("Files")

-- Show first page by default
SearchPage.Visible = true
currentPage = SearchPage

-- // SEARCH PAGE CONTENT // --
local SearchBox = Instance.new("TextBox")
SearchBox.Name = "SearchBox"
SearchBox.Size = UDim2.new(1, 0, 0, 45)
SearchBox.PlaceholderText = "Enter filename to search..."
SearchBox.Text = ""
SearchBox.TextColor3 = Color3.new(1, 1, 1)
SearchBox.Font = Enum.Font.Gotham
SearchBox.TextSize = 14
SearchBox.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
SearchBox.BorderSizePixel = 0
SearchBox.Parent = SearchPage

local SearchCorner = Instance.new("UICorner")
SearchCorner.CornerRadius = UDim.new(0, 6)
SearchCorner.Parent = SearchBox

local SearchPadding = Instance.new("UIPadding")
SearchPadding.PaddingLeft = UDim.new(0, 10)
SearchPadding.Parent = SearchBox

SearchBox.FocusLost:Connect(function(enterPressed)
    if enterPressed and SearchBox.Text ~= "" then
        local path = folderPath .. SearchBox.Text
        if isfile(path) then
            local success, err = pcall(function()
                loadstring(readfile(path))()
            end)
            if success then
                SearchBox.Text = ""
                SearchBox.PlaceholderText = "File executed successfully!"
                wait(2)
                SearchBox.PlaceholderText = "Enter filename to search..."
            else
                warn("Error executing file:", err)
            end
        else
            SearchBox.PlaceholderText = "File not found!"
            wait(2)
            SearchBox.PlaceholderText = "Enter filename to search..."
        end
    end
end)

