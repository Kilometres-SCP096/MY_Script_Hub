local function Refresh()
    -- Clear old cards
    for _, c in pairs(Scroll:GetChildren()) do
        if c:IsA("Frame") then
            c:Destroy()
        end
    end

    local ok, files = pcall(listfiles, MAIN_FOLDER)
    if not ok or #files == 0 then
        local empty = Instance.new("Frame", Scroll)
        empty.Size = UDim2.new(1, -10, 0, 80)
        empty.BackgroundColor3 = Theme.Surface
        empty.BorderSizePixel = 0
        Corner(empty, 10)
        Stroke(empty, Theme.Border, 1, 0.7)

        local emptyLbl = Instance.new("TextLabel", empty)
        emptyLbl.Size = UDim2.new(1, 0, 1, 0)
        emptyLbl.BackgroundTransparency = 1
        emptyLbl.Text = "No saved scripts yet.\nGo to Add tab to save one!"
        emptyLbl.TextColor3 = Theme.TextDim
        emptyLbl.Font = Enum.Font.GothamItalic
        emptyLbl.TextSize = 13
        return
    end

    for i, path in ipairs(files) do
        local name = path:match("([^/\\]+)$") or path

        local card = Instance.new("Frame", Scroll)
        card.Name = "Card_" .. i
        card.Size = UDim2.new(1, -10, 0, 68)
        card.BackgroundColor3 = Theme.Surface
        card.BorderSizePixel = 0
        card.LayoutOrder = i
        Corner(card, 10)
        Stroke(card, Theme.Border, 1, 0.6)

        -- Hover effect
        local hover = Instance.new("Frame", card)
        hover.Size = UDim2.new(1, 0, 1, 0)
        hover.BackgroundColor3 = Theme.Primary
        hover.BackgroundTransparency = 1
        hover.BorderSizePixel = 0
        Corner(hover, 10)

        -- Index number badge
        local badge = Instance.new("Frame", card)
        badge.Size = UDim2.new(0, 28, 0, 28)
        badge.Position = UDim2.new(0, 12, 0.5, -14)
        badge.BackgroundColor3 = Theme.Primary
        badge.BackgroundTransparency = 0.7
        badge.BorderSizePixel = 0
        Corner(badge, 6)

        local badgeNum = Instance.new("TextLabel", badge)
        badgeNum.Size = UDim2.new(1, 0, 1, 0)
        badgeNum.BackgroundTransparency = 1
        badgeNum.Text = tostring(i)
        badgeNum.TextColor3 = Theme.Accent
        badgeNum.Font = Enum.Font.GothamBold
        badgeNum.TextSize = 11

        -- Script name
        local lbl = Instance.new("TextLabel", card)
        lbl.Size = UDim2.new(1, -165, 0, 28)
        lbl.Position = UDim2.new(0, 50, 0, 12)
        lbl.BackgroundTransparency = 1
        lbl.Text = name
        lbl.TextColor3 = Theme.Text
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 13
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.TextTruncate = Enum.TextTruncate.AtEnd

        -- File path dim label
        local pathLbl = Instance.new("TextLabel", card)
        pathLbl.Size = UDim2.new(1, -165, 0, 18)
        pathLbl.Position = UDim2.new(0, 50, 0, 38)
        pathLbl.BackgroundTransparency = 1
        pathLbl.Text = MAIN_FOLDER .. "/" .. name
        pathLbl.TextColor3 = Theme.TextDim
        pathLbl.Font = Enum.Font.Gotham
        pathLbl.TextSize = 10
        pathLbl.TextXAlignment = Enum.TextXAlignment.Left
        pathLbl.TextTruncate = Enum.TextTruncate.AtEnd

        -- Run button
        local run = Btn(card, "▶", function()
            local runOk, runErr = pcall(function()
                loadstring(readfile(path))()
            end)
            if not runOk then
                warn("[Cyber-Neo] Script Error: " .. tostring(runErr))
            end
        end, "Success")
        run.Size = UDim2.new(0, 65, 0, 38)
        run.Position = UDim2.new(1, -148, 0.5, -19)
        run.TextSize = 14

        -- Load into editor button
        local edit = Btn(card, "✎", function()
            Code.Text = readfile(path)
            Switch("Runner")
        end, "Secondary")
        edit.Size = UDim2.new(0, 38, 0, 38)
        edit.Position = UDim2.new(1, -78, 0.5, -19)
        edit.TextSize = 16

        -- Delete button
        local del = Btn(card, "🗑", function()
            delfile(path)
            Refresh()
        end, "Danger")
        del.Size = UDim2.new(0, 38, 0, 38)
        del.Position = UDim2.new(1, -35, 0.5, -19)
        del.TextSize = 14
    end
end

RefreshBtn.MouseButton1Click:Connect(Refresh)

