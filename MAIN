-- SEARCH PAGE
--////////////////////////////////////////////////////
local SearchWrap = make("Frame", {
    BackgroundTransparency = 1,
    Size = UDim2.new(1, 0, 1, 0),
    ZIndex = 10
}, SearchPage)

local SearchBox = input(SearchWrap, "Search script name...", false, 40)
SearchBox.Size = UDim2.new(1, -2, 0, 40)
SearchBox.ZIndex = 20

local SearchHint = label(SearchWrap, "Search only checks script names. Enter exact filename to run immediately.", 12, C.MUTED, false)
SearchHint.Position = UDim2.new(0, 2, 0, 46)
SearchHint.Size = UDim2.new(1, -4, 0, 16)
SearchHint.ZIndex = 12

local SearchResults = make("ScrollingFrame", {
    BackgroundTransparency = 1,
    Position = UDim2.new(0, 0, 0, 68),
    Size = UDim2.new(1, 0, 1, -68),
    ScrollBarThickness = 3,
    AutomaticCanvasSize = Enum.AutomaticSize.Y,
    CanvasSize = UDim2.new(0, 0, 0, 0),
    ZIndex = 10
}, SearchWrap)

local SearchResultsLayout = make("UIListLayout", {
    Padding = UDim.new(0, 8)
}, SearchResults)

local function renderSearchResults(query)
    clearFrameChildren(SearchResults)
    query = trim(query):lower()

    if query == "" then
        local empty = label(SearchResults, "Type a script name to filter results.", 13, C.MUTED, false)
        empty.Size = UDim2.new(1, -4, 0, 24)
        empty.ZIndex = 12
        return
    end

    local matches = 0
    for _, file in ipairs(FileCache) do
        if file.name:lower():find(query, 1, true) then
            buildFileRow(SearchResults, file, true)
            matches += 1
        end
    end

    if matches == 0 then
        local empty = label(SearchResults, "No matching script names found.", 13, C.MUTED, false)
        empty.Size = UDim2.new(1, -4, 0, 24)
        empty.ZIndex = 12
    end
end

SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    renderSearchResults(SearchBox.Text)
end)

SearchBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local path = findExactFileByName(SearchBox.Text)
        if path then
            local ok, err = execFile(path)
            if ok then
                showToast("Executed", relName(path), C.SUCCESS)
            else
                showToast("Error", tostring(err), C.DANGER)
            end
        else
            showToast("Not Found", "Exact script name was not found.", C.DANGER)
        end
    end
end)

