-- [[ FLOATING TOGGLE BALL - PROPER SIZE ]]
-- ========================================

local FloatingBall = Instance.new("ImageButton", ScreenGui)
FloatingBall.Name = "FloatingBall"
FloatingBall.Size = UDim2.new(0, 55, 0, 55) -- SMALLER SIZE
FloatingBall.Position = UDim2.new(0.05, 0, 0.45, 0)
FloatingBall.BackgroundColor3 = Theme.Primary
FloatingBall.Image = "rbxassetid://6031225818"
FloatingBall.ImageColor3 = Theme.Text
FloatingBall.BorderSizePixel = 0
FloatingBall.Visible = false
FloatingBall.ZIndex = 10000

CreateCorner(FloatingBall, 28) -- PERFECT CIRCLE
local ballStroke = CreateStroke(FloatingBall, Theme.Glow, 2.5, 0.3)
CreateGradient(FloatingBall, 45, Theme.Primary, Theme.Secondary)

-- Pulsing Animation
spawn(function()
    while true do
        if FloatingBall.Visible then
            ballStroke.Thickness = 2.5 + math.sin(tick() * 3) * 0.8
            ballStroke.Transparency = 0.3 + math.sin(tick() * 3) * 0.15
        end
        RunService.RenderStepped:Wait()
    end
end)

-- PERFECT DRAGGING SYSTEM
local isDragging = false
local dragStartPos = nil
local ballStartPos = nil
local hasMoved = false

FloatingBall.MouseButton1Down:Connect(function()
    isDragging = true
    hasMoved = false
    dragStartPos = UserInputService:GetMouseLocation()
    ballStartPos = FloatingBall.Position
end)

FloatingBall.MouseButton1Up:Connect(function()
    if not hasMoved then
        -- Click action - show main UI
        MainFrame.Visible = true
        FloatingBall.Visible = false
    end
    isDragging = false
    hasMoved = false
end)

RunService.RenderStepped:Connect(function()
    if isDragging then
        local currentMousePos = UserInputService:GetMouseLocation()
        local delta = currentMousePos - dragStartPos
        
        -- Check if moved more than 5 pixels
        if math.abs(delta.X) > 5 or math.abs(delta.Y) > 5 then
            hasMoved = true
        end
        
        FloatingBall.Position = UDim2.new(
            ballStartPos.X.Scale,
            ballStartPos.X.Offset + delta.X,
            ballStartPos.Y.Scale,
            ballStartPos.Y.Offset + delta.Y
        )
    end
end)

-- ========================================
-- [[ MAIN UI FRAME - 93% SCREEN SIZE ]]
-- ========================================

-- Get viewport size for proper 93% calculation
local Camera = workspace.CurrentCamera
local ViewportSize = Camera.ViewportSize

-- Calculate 93% of screen
local uiWidth = ViewportSize.X * 0.93
local uiHeight = ViewportSize.Y * 0.93

-- Adjust for aspect ratio 6:3.5
local aspectRatio = 6 / 3.5
if uiWidth / uiHeight > aspectRatio then
    uiWidth = uiHeight * aspectRatio
else
    uiHeight = uiWidth / aspectRatio
end

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Name = "MainFrame"
MainFrame.Size = UDim2.new(0, uiWidth, 0, uiHeight)
MainFrame.Position = UDim2.new(0.5, -uiWidth/2, 0.5, -uiHeight/2)
MainFrame.BackgroundColor3 = Theme.Background
MainFrame.BorderSizePixel = 0
MainFrame.ClipsDescendants = true

CreateCorner(MainFrame, 15) -- ROUNDED CORNERS
CreateStroke(MainFrame, Theme.Glow, 2, 0.5)
CreateShadow(MainFrame)

-- ========================================
-- [[ MAKE UI DRAGGABLE ]]
-- ========================================

local draggingUI = false
local dragInputUI = nil
local dragStartUI = nil
local startPosUI = nil

local function MakeUIDraggable(frame, dragHandle)
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingUI = true
            dragStartUI = input.Position
            startPosUI = frame.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInputUI = input
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingUI = false
        end
    end)
    
    RunService.RenderStepped:Connect(function()
        if draggingUI and dragInputUI then
            local delta = dragInputUI.Position - dragStartUI
            frame.Position = UDim2.new(
                startPosUI.X.Scale,
                startPosUI.X.Offset + delta.X,
                startPosUI.Y.Scale,
                startPosUI.Y.Offset + delta.Y
            )
        end
    end)
end

