-- Logic: Switching Pages
local function Switch(name)
    for _, p in pairs(Pages) do p.Visible = false end
    Pages[name].Visible = true
end

-- Logic: Saved Scripts
local function LoadFiles()
    for _, v in pairs(Scroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    local files = listfiles(MAIN_FOLDER)
    for _, path in pairs(files) do
        local name = path:gsub(MAIN_FOLDER.."/", "")
        local row = Instance.new("Frame", Scroll)
        row.Size = UDim2.new(1, 0, 0, 50)
        row.BackgroundColor3 = Color3.fromRGB(30, 25, 45)
        Instance.new("UICorner", row)
        
        local label = Instance.new("TextLabel", row)
        label.Text = "  " .. name
        label.Size = UDim2.new(0.5, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = Color3.new(1,1,1)
        label.TextXAlignment = "Left"
        
        local run = TechBtn("RUN", Color3.fromRGB(80, 150, 80), 0.6)
        run.Parent = row; run.Size = UDim2.new(0, 60, 0.7, 0); run.Position = UDim2.new(0.6, 0, 0.15, 0)
        
        local del = TechBtn("DEL", Color3.fromRGB(150, 50, 50), 0.8)
        del.Parent = row; del.Size = UDim2.new(0, 60, 0.7, 0); del.Position = UDim2.new(0.8, 0, 0.15, 0)
        
        run.MouseButton1Click:Connect(function() loadstring(readfile(path))() end)
        del.MouseButton1Click:Connect(function()
            -- Pop Up
            local pop = Instance.new("Frame", SG)
            pop.Size = UDim2.new(0, 250, 0, 120)
            pop.Position = UDim2.new(0.5, -125, 0.5, -60)
            pop.BackgroundColor3 = Color3.fromRGB(20, 15, 25)
            Instance.new("UIStroke", pop).Color = Color3.fromRGB(200, 50, 50)
            Instance.new("UICorner", pop)
            
            local t = Instance.new("TextLabel", pop)
            t.Text = "Delete Script?"
            t.Size = UDim2.new(1,0,0.5,0); t.TextColor3 = Color3.new(1,1,1); t.BackgroundTransparency = 1
            
            local ok = TechBtn("YES", Color3.fromRGB(150, 50, 50), 0.1)
            ok.Parent = pop; ok.Size = UDim2.new(0.35, 0, 0.3, 0); ok.Position = UDim2.new(0.1, 0, 0.6, 0)
            
            local no = TechBtn("NO", Color3.fromRGB(80, 80, 80), 0.55)
            no.Parent = pop; no.Size = UDim2.new(0.35, 0, 0.3, 0); no.Position = UDim2.new(0.55, 0, 0.6, 0)
            
            ok.MouseButton1Click:Connect(function() delfile(path); pop:Destroy(); LoadFiles() end)
            no.MouseButton1Click:Connect(function() pop:Destroy() end)
        end)
    end
end

-- Navigation Connections
bSearch.MouseButton1Click:Connect(function() Switch("Search") end)
bAdd.MouseButton1Click:Connect(function() Switch("Add") end)
bRun.MouseButton1Click:Connect(function() Switch("Runner") end)
bSaved.MouseButton1Click:Connect(function() Switch("Saved"); LoadFiles() end)

-- Feature Connections
btn_Run.MouseButton1Click:Connect(function() loadstring(CodeEditor.Text)() end)
btn_Clear.MouseButton1Click:Connect(function() CodeEditor.Text = "" end)
btn_ToSave.MouseButton1Click:Connect(function() CodeIn.Text = CodeEditor.Text; Switch("Add") end)
btn_FinalSave.MouseButton1Click:Connect(function()
    if NameIn.Text ~= "" then
        writefile(MAIN_FOLDER .. "/" .. NameIn.Text, CodeIn.Text)
        NameIn.Text = ""; CodeIn.Text = ""
        Switch("Saved"); LoadFiles()
    end
end)

