-- ========================================
-- [[ COLOR THEME - CYBER PURPLE ]]
-- ========================================
local Theme = {
    Background = Color3.fromRGB(10, 8, 15),
    Sidebar = Color3.fromRGB(18, 14, 25),
    Surface = Color3.fromRGB(25, 20, 35),
    Primary = Color3.fromRGB(140, 80, 255),
    Secondary = Color3.fromRGB(100, 50, 200),
    Accent = Color3.fromRGB(180, 120, 255),
    Success = Color3.fromRGB(80, 200, 120),
    Danger = Color3.fromRGB(220, 80, 80),
    Warning = Color3.fromRGB(255, 180, 60),
    Text = Color3.fromRGB(245, 245, 250),
    TextDim = Color3.fromRGB(160, 150, 180),
    Border = Color3.fromRGB(60, 40, 100),
    Glow = Color3.fromRGB(200, 140, 255),
}

-- ========================================
-- [[ UTILITY FUNCTIONS ]]
-- ========================================

local function CreateCorner(parent, radius)
    local corner = Instance.new("UICorner", parent)
    corner.CornerRadius = UDim.new(0, radius or 12)
    return corner
end

local function CreateStroke(parent, color, thickness, transparency)
    local stroke = Instance.new("UIStroke", parent)
    stroke.Color = color or Theme.Border
    stroke.Thickness = thickness or 1
    stroke.Transparency = transparency or 0.5
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    return stroke
end

local function CreateGradient(parent, rotation, c1, c2)
    local gradient = Instance.new("UIGradient", parent)
    gradient.Rotation = rotation or 90
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, c1 or Theme.Primary),
        ColorSequenceKeypoint.new(1, c2 or Theme.Secondary)
    })
    return gradient
end

local function CreateShadow(parent)
    local shadow = Instance.new("ImageLabel", parent)
    shadow.Name = "Shadow"
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://1316045217"
    shadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
    shadow.ImageTransparency = 0.7
    shadow.Size = UDim2.new(1, 40, 1, 40)
    shadow.Position = UDim2.new(0, -20, 0, -20)
    shadow.ZIndex = parent.ZIndex - 1
    return shadow
end

local function TweenProperty(object, property, endValue, duration)
    local info = TweenInfo.new(duration or 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(object, info, {[property] = endValue})
    tween:Play()
    return tween
end

local function CreateButton(parent, text, callback, style)
    style = style or "Primary"
    
    local button = Instance.new("TextButton", parent)
    button.BackgroundColor3 = Theme[style] or Theme.Primary
    button.BorderSizePixel = 0
    button.Font = Enum.Font.GothamBold
    button.Text = text
    button.TextColor3 = Theme.Text
    button.TextSize = 13
    button.AutoButtonColor = false
    
    CreateCorner(button, 8)
    local stroke = CreateStroke(button, Theme.Glow, 1.5, 0.7)
    
    local originalColor = button.BackgroundColor3
    
    button.MouseEnter:Connect(function()
        TweenProperty(button, "BackgroundColor3", originalColor:Lerp(Color3.new(1,1,1), 0.15))
        TweenProperty(stroke, "Transparency", 0.2)
    end)
    
    button.MouseLeave:Connect(function()
        TweenProperty(button, "BackgroundColor3", originalColor)
        TweenProperty(stroke, "Transparency", 0.7)
    end)
    
    button.MouseButton1Down:Connect(function()
        TweenProperty(button, "BackgroundColor3", originalColor:Lerp(Color3.new(0,0,0), 0.2))
    end)
    
    button.MouseButton1Up:Connect(function()
        TweenProperty(button, "BackgroundColor3", originalColor)
    end)
    
    if callback then
        button.MouseButton1Click:Connect(callback)
    end
    
    return button
end

local function CreateTextBox(parent, placeholder, multiline)
    local textbox = Instance.new("TextBox", parent)
    textbox.BackgroundColor3 = Theme.Surface
    textbox.BorderSizePixel = 0
    textbox.Font = Enum.Font.Gotham
    textbox.PlaceholderText = placeholder or ""
    textbox.Text = ""
    textbox.TextColor3 = Theme.Text
    textbox.TextSize = 12
    textbox.ClearTextOnFocus = false
    textbox.MultiLine = multiline or false
    textbox.TextXAlignment = multiline and "Left" or "Center"
    textbox.TextYAlignment = multiline and "Top" or "Center"
    
    CreateCorner(textbox, 8)
    CreateStroke(textbox, Theme.Border, 1, 0.6)
    
    local padding = Instance.new("UIPadding", textbox)
    padding.PaddingLeft = UDim.new(0, 10)
    padding.PaddingRight = UDim.new(0, 10)
    padding.PaddingTop = UDim.new(0, multiline and 10 or 0)
    padding.PaddingBottom = UDim.new(0, multiline and 10 or 0)
    
    return textbox
end

local function CreateIconButton(parent, iconId, callback)
    local button = Instance.new("ImageButton", parent)
    button.BackgroundColor3 = Theme.Surface
    button.BorderSizePixel = 0
    button.Image = iconId
    button.ImageColor3 = Theme.TextDim
    button.AutoButtonColor = false
    
    CreateCorner(button, 10)
    local stroke = CreateStroke(button, Theme.Border, 1.5, 0.8)
    
    button.MouseEnter:Connect(function()
        TweenProperty(button, "ImageColor3", Theme.Accent)
        TweenProperty(button, "BackgroundColor3", Theme.Surface:Lerp(Theme.Primary, 0.1))
        TweenProperty(stroke, "Transparency", 0.3)
    end)
    
    button.MouseLeave:Connect(function()
        TweenProperty(button, "ImageColor3", Theme.TextDim)
        TweenProperty(button, "BackgroundColor3", Theme.Surface)
        TweenProperty(stroke, "Transparency", 0.8)
    end)
    
    if callback then
        button.MouseButton1Click:Connect(callback)
    end
    
    return button
end

