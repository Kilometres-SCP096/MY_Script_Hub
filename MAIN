local PSe = Page("Search")
PageHeader(PSe, "🔍", "Search Scripts", "Find your saved scripts quickly")

local SIn = TBox(PSe, "🔍  Search by name...")
SIn.Size = UDim2.new(1, 0, 0, 45)
SIn.Position = UDim2.new(0, 0, 0, 52)

local SearchScroll = Instance.new("ScrollingFrame", PSe)
SearchScroll.Size = UDim2.new(1, 0, 1, -110)
SearchScroll.Position = UDim2.new(0, 0, 0, 110)
SearchScroll.BackgroundTransparency = 1
SearchScroll.BorderSizePixel = 0
SearchScroll.ScrollBarThickness = 5
SearchScroll.ScrollBarImageColor3 = Theme.Primary
SearchScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
SearchScroll.AutomaticCanvasSize = Enum.AutomaticCanvasSize.Y
SearchScroll.ClipsDescendants = true
SearchScroll.ScrollingDirection = Enum.ScrollingDirection.Y

local SSL = Instance.new("UIListLayout", SearchScroll)
SSL.Padding = UDim.new(0, 10)
SSL.SortOrder = Enum.SortOrder.LayoutOrder
SSL.HorizontalAlignment = Enum.HorizontalAlignment.Center

local SSLPad = Instance.new("UIPadding", SearchScroll)
SSLPad.PaddingTop = UDim.new(0, 5)
SSLPad.PaddingBottom = UDim.new(0, 10)
SSLPad.PaddingLeft = UDim.new(0, 2)
SSLPad.PaddingRight = UDim.new(0, 8)

local function DoSearch(query)
    for _, c in pairs(SearchScroll:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end

    local ok, files = pcall(listfiles, MAIN_FOLDER)
    if not ok then return end

    local count = 0
    for i, path in ipairs(files) do
        local name = path:match("([^/\\]+)$") or path
        if query == "" or name:lower():find(query:lower(), 1, true) then
            count = count + 1
            local card = Instance.new("Frame", SearchScroll)
            card.Name = "SCard_" .. i
            card.Size = UDim2.new(1, -10, 0, 65)
            card.BackgroundColor3 = Theme.Surface
            card.BorderSizePixel = 0
            card.LayoutOrder = count
            Corner(card, 10)
            Stroke(card, Theme.Border, 1, 0.6)

            local lbl = Instance.new("TextLabel", card)
            lbl.Size = UDim2.new(1, -130, 1, 0)
            lbl.Position = UDim2.new(0, 12, 0, 0)
            lbl.BackgroundTransparency = 1
            lbl.Text = "📄 " .. name
            lbl.TextColor3 = Theme.Text
            lbl.Font = Enum.Font.GothamBold
            lbl.TextSize = 13
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.TextTruncate = Enum.TextTruncate.AtEnd

            local run = Btn(card, "▶ RUN", function()
                pcall(function() loadstring(readfile(path))() end)
            end, "Success")
            run.Size = UDim2.new(0, 80, 0, 38)
            run.Position = UDim2.new(1, -120, 0.5, -19)
            run.TextSize = 12

            local loadBtn = Btn(card, "✎", function()
                Code.Text = readfile(path)
                Switch("Runner")
            end, "Secondary")
            loadBtn.Size = UDim2.new(0, 35, 0, 38)
            loadBtn.Position = UDim2.new(1, -35, 0.5, -19)
            loadBtn.TextSize = 14
        end
    end

    if count == 0 then
        local noResult = Instance.new("Frame", SearchScroll)
        noResult.Size = UDim2.new(1, -10, 0, 60)
        noResult.BackgroundColor3 = Theme.Surface
        noResult.BorderSizePixel = 0
        Corner(noResult, 10)
        local noLbl = Instance.new("TextLabel", noResult)
        noLbl.Size = UDim2.new(1, 0, 1, 0)
        noLbl.BackgroundTransparency = 1
        noLbl.Text = 'No scripts found for "' .. query .. '"'
        noLbl.TextColor3 = Theme.TextDim
        noLbl.Font = Enum.Font.GothamItalic
        noLbl.TextSize = 13
    end
end

SIn:GetPropertyChangedSignal("Text"):Connect(function()
    DoSearch(SIn.Text)
end)

