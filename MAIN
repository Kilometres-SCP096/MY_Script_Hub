local function CreateNavBtn(name, iconID)
    local btn = Instance.new("ImageButton", Sidebar)
    btn.Name = name
    btn.Size = UDim2.new(0, 35, 0, 35)
    btn.BackgroundTransparency = 1
    btn.Image = "rbxassetid://" .. iconID
    btn.ImageColor3 = Color3.fromRGB(150, 120, 200)
    
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.3), {ImageColor3 = Color3.fromRGB(255, 255, 255)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.3), {ImageColor3 = Color3.fromRGB(150, 120, 200)}):Play()
    end)
    return btn
end

local bSearch = CreateNavBtn("Search", "6031154871")
