local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local folderPath = "My_Script_Hub/"
if not isfolder(folderPath) then makefolder(folderPath) end

-- // CLEANUP // --
if CoreGui:FindFirstChild("StrongerHub_Fixed") then
    CoreGui.StrongerHub_Fixed:Destroy()
end

-- // MAIN UI // --
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "StrongerHub_Fixed"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling   -- IMPORTANT FIX

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 450, 0, 300)
MainFrame.Position = UDim2.new(0.5, -225, 0.5, -150)
MainFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
MainFrame.BorderSizePixel = 0
MainFrame.Visible = true

Instance.new("UICorner", MainFrame)
local Stroke = Instance.new("UIStroke", MainFrame)
Stroke.Color = Color3.fromRGB(138, 43, 226)
Stroke.Thickness = 2

-- // TOGGLE BUTTON // --
local ToggleButton = Instance.new("TextButton", ScreenGui)
ToggleButton.Size = UDim2.new(0, 45, 0, 45)
ToggleButton.Position = UDim2.new(0, 20, 0, 20)
ToggleButton.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
ToggleButton.Text = "K"
ToggleButton.TextColor3 = Color3.fromRGB(138, 43, 226)
ToggleButton.Font = Enum.Font.GothamBold
ToggleButton.TextSize = 20
ToggleButton.ZIndex = 10

Instance.new("UICorner", ToggleButton).CornerRadius = UDim.new(1, 0)
local TStroke = Instance.new("UIStroke", ToggleButton)
TStroke.Color = Color3.fromRGB(138, 43, 226)

ToggleButton.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
end)

-- // SIDEBAR // --
local Sidebar = Instance.new("Frame", MainFrame)
Sidebar.Size = UDim2.new(0, 110, 1, -10)
Sidebar.Position = UDim2.new(0, 5, 0, 5)
Sidebar.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Instance.new("UICorner", Sidebar)

local SideLayout = Instance.new("UIListLayout", Sidebar)
SideLayout.Padding = UDim.new(0, 5)
SideLayout.SortOrder = Enum.SortOrder.LayoutOrder
SideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

local SidePadding = Instance.new("UIPadding", Sidebar)  -- FIX
SidePadding.PaddingTop = UDim.new(0, 8)
SidePadding.PaddingBottom = UDim.new(0, 8)

-- // PAGES CONTAINER // --
local Pages = Instance.new("Frame", MainFrame)
Pages.Size = UDim2.new(1, -130, 1, -10)
Pages.Position = UDim2.new(0, 120, 0, 5)
Pages.BackgroundTransparency = 1

local function CreatePage(name)
    local Page = Instance.new("ScrollingFrame", Pages)
    Page.Name = name
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.Visible = false
    Page.BackgroundTransparency = 1
    Page.ScrollBarThickness = 4
    Page.ScrollBarImageColor3 = Color3.fromRGB(138, 43, 226)
    Page.CanvasSize = UDim2.new(0,0,0,0)
    Page.AutomaticCanvasSize = Enum.AutomaticCanvasSize.Y
    
    local Layout = Instance.new("UIListLayout", Page)
    Layout.Padding = UDim.new(0, 8)
    Layout.SortOrder = Enum.SortOrder.LayoutOrder
    
    local PagePadding = Instance.new("UIPadding", Page)   -- FIX
    PagePadding.PaddingLeft = UDim.new(0, 8)
    PagePadding.PaddingRight = UDim.new(0, 8)
    PagePadding.PaddingTop = UDim.new(0, 5)
    
    local TabBtn = Instance.new("TextButton", Sidebar)
    TabBtn.Size = UDim2.new(0.9, 0, 0, 35)
    TabBtn.Text = name
    TabBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    TabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    Instance.new("UICorner", TabBtn)
    
    TabBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages:GetChildren()) do
            if p:IsA("ScrollingFrame") then p.Visible = false end
        end
        Page.Visible = true
    end)
    
    return Page
end

local SearchPage = CreatePage("Search")
local ManagePage = CreatePage("Manage")
local FilesPage = CreatePage("Files")
SearchPage.Visible = true

-- // SEARCH PAGE // --
local SearchInput = Instance.new("TextBox", SearchPage)
SearchInput.Size = UDim2.new(1, 0, 0, 40)
SearchInput.PlaceholderText = "Type File Name..."
SearchInput.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
SearchInput.TextColor3 = Color3.fromRGB(255, 255, 255)
Instance.new("UICorner", SearchInput)

SearchInput.FocusLost:Connect(function()
    local path = folderPath .. SearchInput.Text
    if isfile(path) then
        loadstring(readfile(path))()
    end
end)

-- // MANAGE PAGE // --
local function CreateManageInput(placeholder)
    local box = Instance.new("TextBox", ManagePage)
    box.Size = UDim2.new(1, 0, 0, 35)
    box.PlaceholderText = placeholder
    box.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    box.ClearTextOnFocus = false
    Instance.new("UICorner", box)
    return box
end

local NameIn = CreateManageInput("filename.lua")
local CodeIn = CreateManageInput("Paste Code Here...")

local SaveBtn = Instance.new("TextButton", ManagePage)
SaveBtn.Size = UDim2.new(1, 0, 0, 35)
SaveBtn.Text = "SAVE TO WORKSPACE"
SaveBtn.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
SaveBtn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", SaveBtn)

SaveBtn.MouseButton1Click:Connect(function()
    if NameIn.Text ~= "" then
        writefile(folderPath .. NameIn.Text, CodeIn.Text)
    end
end)

-- // FILES PAGE // --
local function RefreshList()
    -- Don't destroy the refresh button
    for _, v in pairs(FilesPage:GetChildren()) do
        if v:IsA("TextButton") and v.Name ~= "RefreshBtn" then 
            v:Destroy() 
        end
    end
    
    for _, file in pairs(listfiles(folderPath)) do
        local name = file:gsub(folderPath, "")
        local Btn = Instance.new("TextButton", FilesPage)
        Btn.Size = UDim2.new(1, 0, 0, 35)
        Btn.Text = "▶️ " .. name
        Btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        Btn.TextColor3 = Color3.fromRGB(200, 200, 200)
        Btn.TextXAlignment = Enum.TextXAlignment.Left
        Instance.new("UICorner", Btn)
        
        Btn.MouseButton1Click:Connect(function()
            loadstring(readfile(file))()
        end)
    end
end

local RefBtn = Instance.new("TextButton", FilesPage)
RefBtn.Name = "RefreshBtn"
RefBtn.Size = UDim2.new(1, 0, 0, 35)
RefBtn.Text = "🔄 REFRESH LIST"
RefBtn.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
RefBtn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", RefBtn)
RefBtn.MouseButton1Click:Connect(RefreshList)

-- // DRAG // --
local function MakeDraggable(gui)
    local dragging, dragInput, dragStart, startPos
    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = gui.Position
        end
    end)
    gui.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then 
            dragInput = input 
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            gui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            dragging = false 
        end
    end)
end

MakeDraggable(MainFrame)
RefreshList()

print("StrongerHub Fixed - Loaded!")
