local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local folderPath = "My_Script_Hub/"

-- // 1. COMPLETE RESET // --
if CoreGui:FindFirstChild("FORCED_HUB") then CoreGui.FORCED_HUB:Destroy() end

-- // 2. THE BASE // --
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "FORCED_HUB"
ScreenGui.DisplayOrder = 9999
ScreenGui.IgnoreGuiInset = true

-- // 3. THE TOGGLE (RAYFIELD STYLE) // --
local Toggle = Instance.new("TextButton", ScreenGui)
Toggle.Size = UDim2.new(0, 55, 0, 55)
Toggle.Position = UDim2.new(0, 15, 0, 15)
Toggle.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Toggle.Text = "SHOW"
Toggle.TextColor3 = Color3.fromRGB(138, 43, 226)
Toggle.ZIndex = 1000
Instance.new("UICorner", Toggle).CornerRadius = UDim.new(1, 0)
local TStroke = Instance.new("UIStroke", Toggle)
TStroke.Color = Color3.fromRGB(138, 43, 226)
TStroke.Thickness = 3

-- // 4. THE MAIN FRAME // --
local Main = Instance.new("Frame", ScreenGui)
Main.Name = "Container"
Main.Size = UDim2.new(0, 460, 0, 320)
Main.Position = UDim2.new(0.5, -230, 0.5, -160)
Main.BackgroundColor3 = Color3.fromRGB(5, 5, 5) -- Ultra Dark
Main.BorderSizePixel = 0
Main.ZIndex = 5
Main.Visible = true -- Starts visible so you can see it work

Instance.new("UICorner", Main)
local MStroke = Instance.new("UIStroke", Main)
MStroke.Color = Color3.fromRGB(138, 43, 226)
MStroke.Thickness = 2

Toggle.MouseButton1Click:Connect(function()
    Main.Visible = not Main.Visible
end)

-- // 5. THE SIDEBAR // --
local Sidebar = Instance.new("Frame", Main)
Sidebar.Size = UDim2.new(0, 120, 1, -20)
Sidebar.Position = UDim2.new(0, 10, 0, 10)
Sidebar.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Sidebar.ZIndex = 10 
Instance.new("UICorner", Sidebar)

local SideLayout = Instance.new("UIListLayout", Sidebar)
SideLayout.Padding = UDim.new(0, 5)
SideLayout.HorizontalAlignment = "Center"

-- // 6. THE CONTENT AREA // --
local Content = Instance.new("Frame", Main)
Content.Size = UDim2.new(1, -150, 1, -20)
Content.Position = UDim2.new(0, 140, 0, 10)
Content.BackgroundTransparency = 1
Content.ZIndex = 10

-- // 7. SCRIPT LIST (THE ACTUAL ELEMENTS) // --
local Scroll = Instance.new("ScrollingFrame", Content)
Scroll.Size = UDim2.new(1, 0, 1, 0)
Scroll.BackgroundTransparency = 1
Scroll.ZIndex = 15
Scroll.ScrollBarThickness = 4
Scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
Scroll.AutomaticCanvasSize = "Y"

local ScrollLayout = Instance.new("UIListLayout", Scroll)
ScrollLayout.Padding = UDim.new(0, 8)

-- // 8. FORCED ELEMENT GENERATION // --
local function AddElement(name, callback)
    local Btn = Instance.new("TextButton")
    Btn.Name = "ELEMENT_" .. name
    Btn.Parent = Scroll -- Forced parenting
    Btn.Size = UDim2.new(1, -10, 0, 45)
    Btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Btn.Text = "  " .. name
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.TextXAlignment = "Left"
    Btn.Font = "GothamBold"
    Btn.TextSize = 14
    Btn.ZIndex = 50 -- EXTREMELY HIGH ZINDEX
    
    Instance.new("UICorner", Btn)
    local BStroke = Instance.new("UIStroke", Btn)
    BStroke.Color = Color3.fromRGB(138, 43, 226)
    BStroke.ApplyStrokeMode = "Border"
    
    Btn.MouseButton1Click:Connect(callback)
    print("Element Created: " .. name) -- Check your F9 console!
end

-- // 9. LOAD YOUR 19+ FILES // --
local function LoadFiles()
    -- Clear old buttons first
    for _, v in pairs(Scroll:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end

    if isfolder(folderPath) then
        for _, file in pairs(listfiles(folderPath)) do
            local cleanName = file:gsub(folderPath, "")
            AddElement("▶️ " .. cleanName, function()
                loadstring(readfile(file))()
            end)
        end
    else
        AddElement("❌ FOLDER NOT FOUND", function() end)
    end
end

-- Refresh Button at the top
AddElement("🔄 REFRESH SCRIPTS", function()
    LoadFiles()
end)

-- Initial Load
LoadFiles()

-- // 10. DRAG LOGIC // --
Main.Active = true
Main.Draggable = true
