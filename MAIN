-- ========================================
-- SAVED
-- ========================================
local PS = Page("Saved")
local Scroll = Instance.new("ScrollingFrame", PS)
Scroll.Size = UDim2.new(1, 0, 1, -40)
Scroll.Position = UDim2.new(0, 0, 0, 40)
Scroll.BackgroundTransparency = 1
Scroll.BorderSizePixel = 0
Scroll.ScrollBarThickness = 5
local SL = Instance.new("UIListLayout", Scroll)
SL.Padding = UDim.new(0, 10)

local function Refresh()
    for _, c in pairs(Scroll:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
    for _, path in pairs(listfiles(MAIN_FOLDER)) do
        local name = path:gsub(MAIN_FOLDER.."/", "")
        local card = Instance.new("Frame", Scroll)
        card.Size = UDim2.new(1, -8, 0, 60)
        card.BackgroundColor3 = Theme.Surface
        card.BorderSizePixel = 0
        Corner(card, 10)
        
        local lbl = Instance.new("TextLabel", card)
        lbl.Size = UDim2.new(0.6, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = "  " .. name
        lbl.TextColor3 = Theme.Text
        lbl.Font = Enum.Font.GothamBold
        lbl.TextXAlignment = "Left"
        
        local run = Btn(card, "▶", function() loadstring(readfile(path))() end, "Success")
        run.Size = UDim2.new(0, 50, 0.7, 0)
        run.Position = UDim2.new(1, -120, 0.15, 0)
        
        local del = Btn(card, "🗑", function() delfile(path) Refresh() end, "Danger")
        del.Size = UDim2.new(0, 50, 0.7, 0)
        del.Position = UDim2.new(1, -60, 0.15, 0)
    end
end

