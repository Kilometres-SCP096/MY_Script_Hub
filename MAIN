local navBtns = {}
local function Nav(icon, page, ord)
    local b = IconBtn(NavCont, icon)
    b.Size = UDim2.new(0, 52, 0, 52)
    b.LayoutOrder = ord
    b.MouseButton1Click:Connect(function() Switch(page) for _, n in pairs(navBtns) do Tween(n, "BackgroundColor3", Theme.Surface) end Tween(b, "BackgroundColor3", Theme.Primary) end)
    table.insert(navBtns, b)
end

Nav("rbxassetid://6031154871", "Search", 1)
