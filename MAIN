local SG = Instance.new("ScreenGui")
SG.Name = "CyberNeoHub"
SG.Parent = CoreGui
SG.ResetOnSpawn = false
SG.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

-- ========================================
-- FLOATING BALL
-- ========================================
local Ball = Instance.new("ImageButton", SG)
Ball.Size = UDim2.new(0, 55, 0, 55)
Ball.Position = UDim2.new(0.05, 0, 0.45, 0)
Ball.BackgroundColor3 = Theme.Primary
Ball.Image = "rbxassetid://6031225818"
Ball.ImageColor3 = Theme.Text
Ball.BorderSizePixel = 0
Ball.Visible = false
Ball.ZIndex = 10000
Ball.Active = true
Ball.AutoButtonColor = false
Corner(Ball, 28)
local bStroke = Stroke(Ball, Theme.Glow, 2.5, 0.3)
Gradient(Ball, 45, Theme.Primary, Theme.Secondary)

spawn(function()
    while true do
        if Ball.Visible then
            bStroke.Thickness = 2.5 + math.sin(tick() * 3) * 0.8
            bStroke.Transparency = 0.3 + math.sin(tick() * 3) * 0.15
        end
        RunService.RenderStepped:Wait()
    end
end)

local bDrag, bStart, bPos, bMoved = false, nil, nil, false

Ball.MouseButton1Down:Connect(function()
    bDrag = true
    bMoved = false
    bStart = UserInputService:GetMouseLocation()
    bPos = Ball.Position
end)

Ball.MouseButton1Up:Connect(function()
    if not bMoved and MainFrame then
        MainFrame.Visible = true
        Ball.Visible = false
    end
    bDrag = false
    bMoved = false
end)

RunService.RenderStepped:Connect(function()
    if bDrag then
        local cur = UserInputService:GetMouseLocation()
        local delta = cur - bStart
        if math.abs(delta.X) > 5 or math.abs(delta.Y) > 5 then
            bMoved = true
        end
        Ball.Position = UDim2.new(
            bPos.X.Scale,
            bPos.X.Offset + delta.X,
            bPos.Y.Scale,
            bPos.Y.Offset + delta.Y
        )
    end
end)

-- ========================================
-- VIEWPORT
-- ========================================
local function WaitViewport()
    local c = workspace.CurrentCamera
    local a = 0
    while (not c or c.ViewportSize.X < 200) and a < 100 do
        RunService.RenderStepped:Wait()
        c = workspace.CurrentCamera
        a = a + 1
    end
    return c.ViewportSize
end

local VP = WaitViewport()
local w, h = VP.X * 0.93, VP.Y * 0.93
local ar = 6 / 3.5
if w / h > ar then
    w = h * ar
else
    h = w / ar
end

