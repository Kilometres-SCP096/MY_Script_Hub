ConfirmBtn.Position = UDim2.new(0.52, 0, 1, -46)
ConfirmBtn.ZIndex = 803

local pendingDeletePath = nil

local function openDeletePrompt(path)
    pendingDeletePath = path
    PromptTarget.Text = relName(path)
    Prompt.Visible = true
    PromptShade.Visible = true
end

local function closeDeletePrompt()
    pendingDeletePath = nil
    Prompt.Visible = false
    PromptShade.Visible = false
end

CancelBtn.MouseButton1Click:Connect(closeDeletePrompt)
PromptShade.MouseButton1Click:Connect(closeDeletePrompt)

ConfirmBtn.MouseButton1Click:Connect(function()
    if pendingDeletePath and isfile(pendingDeletePath) then
        safeCall(delfile, pendingDeletePath)
        showToast("Deleted", relName(pendingDeletePath) .. " removed.", C.DANGER)
        closeDeletePrompt()
        task.defer(function()
            task.wait(0.05)
            -- refresh after delete
            local ok = pcall(function()
                -- forward declared below
            end)
        end)
    else
        closeDeletePrompt()
    end
end)

--////////////////////////////////////////////////////
-- FILE CACHE / RENDERING
--////////////////////////////////////////////////////
local FileCache = {}
local FilesContainer = make("Frame", {
    BackgroundTransparency = 1,
    Size = UDim2.new(1, 0, 0, 0),
    ZIndex = 10
}, FilesPage)

local FilesLayout = make("UIListLayout", {
    Padding = UDim.new(0, 8),
    SortOrder = Enum.SortOrder.LayoutOrder
}, FilesContainer)

local function scanFiles()
    FileCache = {}
    local files = {}
    if isfolder(folderPath) then
        files = listfiles(folderPath)
    end

    table.sort(files, function(a, b)
        return relName(a):lower() < relName(b):lower()
    end)

    for _, path in ipairs(files) do
        local name = relName(path)
        FileCache[#FileCache + 1] = {
            path = path,
            name = name,
            size = getFileSize(path)
        }
    end

    StatsLabel.Text = tostring(#FileCache) .. " files"
end

local function buildFileRow(parent, file, isResultRow)
    local row = make("Frame", {
        BackgroundColor3 = C.SURFACE,
        Size = UDim2.new(1, -2, 0, 58),
        BorderSizePixel = 0,
        ZIndex = 10
    }, parent)
    corner(row, 10)
    stroke(row, C.ACCENT, 1, 0.9)
    pad(row, 10, 10, 8, 8)

    local name = label(row, file.name, 14, C.TEXT, true)
    name.Size = UDim2.new(1, -160, 0, 20)
    name.ZIndex = 12

    local meta = label(row, getDisplaySize(file.size), 12, C.MUTED, false)
    meta.Position = UDim2.new(0, 0, 0, 24)
    meta.Size = UDim2.new(1, -160, 0, 16)
    meta.ZIndex = 12

    local RunBtn = button(row, "Run", C.ACCENT, Color3.new(1,1,1), 13)
    RunBtn.Size = UDim2.new(0, 56, 0, 34)
    RunBtn.Position = UDim2.new(1, -124, 0.5, -17)
    RunBtn.ZIndex = 20

    local DelBtn = button(row, "Del", C.DANGER, Color3.new(1,1,1), 13)
    DelBtn.Size = UDim2.new(0, 56, 0, 34)
    DelBtn.Position = UDim2.new(1, -62, 0.5, -17)
    DelBtn.ZIndex = 20

    RunBtn.MouseButton1Click:Connect(function()
        local ok, err = execFile(file.path)
        if ok then
            showToast("Running", file.name, C.SUCCESS)
        else
            showToast("Error", tostring(err), C.DANGER)
        end
    end)

    DelBtn.MouseButton1Click:Connect(function()
        openDeletePrompt(file.path)
    end)

    return row
end

local function renderFiles()
    clearFrameChildren(FilesContainer)
    for _, file in ipairs(FileCache) do
        buildFileRow(FilesContainer, file, false)
    end
end

local function refreshFiles()
    scanFiles()
    renderFiles()
end

RefreshBtn.MouseButton1Click:Connect(function()
    refreshFiles()
    showToast("Refreshed", "File list updated.", C.SUCCESS)
end)

