-- // FILES PAGE CONTENT // --
local RefreshButton = Instance.new("TextButton")
RefreshButton.Name = "RefreshButton"
RefreshButton.Size = UDim2.new(1, 0, 0, 45)
RefreshButton.Text = "🔄 REFRESH FILES"
RefreshButton.TextColor3 = Color3.new(1, 1, 1)
RefreshButton.Font = Enum.Font.GothamBold
RefreshButton.TextSize = 16
RefreshButton.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
RefreshButton.BorderSizePixel = 0
RefreshButton.LayoutOrder = 0
RefreshButton.Parent = FilesPage

local RefreshCorner = Instance.new("UICorner")
RefreshCorner.CornerRadius = UDim.new(0, 6)
RefreshCorner.Parent = RefreshButton

local function RefreshFileList()
    -- Remove old file buttons
    for _, child in pairs(FilesPage:GetChildren()) do
        if child:IsA("TextButton") and child.Name ~= "RefreshButton" then
            child:Destroy()
        end
    end
    
    -- Add file buttons
    local files = listfiles(folderPath)
    for i, filepath in pairs(files) do
        local filename = filepath:gsub(folderPath, "")
        
        local FileButton = Instance.new("TextButton")
        FileButton.Name = "File_" .. i
        FileButton.Size = UDim2.new(1, 0, 0, 40)
        FileButton.Text = "▶ " .. filename
        FileButton.TextColor3 = Color3.fromRGB(200, 200, 200)
        FileButton.Font = Enum.Font.Gotham
        FileButton.TextSize = 13
        FileButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        FileButton.BorderSizePixel = 0
        FileButton.TextXAlignment = Enum.TextXAlignment.Left
        FileButton.LayoutOrder = i
        FileButton.Parent = FilesPage
        
        local FileCorner = Instance.new("UICorner")
        FileCorner.CornerRadius = UDim.new(0, 6)
        FileCorner.Parent = FileButton
        
        local FilePadding = Instance.new("UIPadding")
        FilePadding.PaddingLeft = UDim.new(0, 10)
        FilePadding.Parent = FileButton
        
        FileButton.MouseButton1Click:Connect(function()
            local success, err = pcall(function()
                loadstring(readfile(filepath))()
            end)
            if not success then
                warn("Error running file:", err)
            end
        end)
    end
end

RefreshButton.MouseButton1Click:Connect(RefreshFileList)

-- // DRAG FUNCTIONALITY // --
local function MakeDraggable(frame)
    local dragging = false
    local dragInput, dragStart, startPos

    local function update(input)
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
end

MakeDraggable(MainFrame)
MakeDraggable(ToggleButton)

-- Initial file list load
RefreshFileList()

print("✅ Stronger Hub loaded successfully!")
