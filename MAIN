        local fname = NameIn.Text
        if not fname:find("%.") then
            fname = fname .. ".lua"
        end
        writefile(MAIN_FOLDER .. "/" .. fname, CodeIn.Text)
        NameIn.Text = ""
        CodeIn.Text = ""
        Switch("Saved")
    end
end, "Primary")
SaveBtn.Size = UDim2.new(1, 0, 0, 48)
SaveBtn.Position = UDim2.new(0, 0, 1, -52)

