--// CYBER NEO HUB - STABLE CORE BUILD

local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

--// Remove old
if CoreGui:FindFirstChild("CyberNeoHub") then
    CoreGui.CyberNeoHub:Destroy()
end

--// Theme
local Theme = {
    BG = Color3.fromRGB(15,12,20),
    Surface = Color3.fromRGB(22,18,30),
    Accent = Color3.fromRGB(170,120,255),
    Text = Color3.fromRGB(240,240,255)
}

--// ScreenGui
local GUI = Instance.new("ScreenGui")
GUI.Name = "CyberNeoHub"
GUI.ResetOnSpawn = false
GUI.Parent = CoreGui
GUI.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

--// MAIN FRAME (93% EXACT)
local Main = Instance.new("Frame")
Main.Parent = GUI
Main.Size = UDim2.new(0.93,0,0.93,0)
Main.Position = UDim2.new(0.5,0,0.5,0)
Main.AnchorPoint = Vector2.new(0.5,0.5)
Main.BackgroundColor3 = Theme.BG
Main.BorderSizePixel = 0
Main.ClipsDescendants = true

-- Perfect 6:3.5
local Aspect = Instance.new("UIAspectRatioConstraint")
Aspect.Parent = Main
Aspect.AspectRatio = 6/3.5

-- Rounded
local Corner = Instance.new("UICorner")
Corner.Parent = Main
Corner.CornerRadius = UDim.new(0,20)

-- Stroke
local Stroke = Instance.new("UIStroke")
Stroke.Parent = Main
Stroke.Color = Theme.Accent
Stroke.Thickness = 2
Stroke.Transparency = 0.4

--// TOPBAR
local Top = Instance.new("Frame")
Top.Parent = Main
Top.Size = UDim2.new(1,0,0,60)
Top.BackgroundColor3 = Theme.Surface
Top.BorderSizePixel = 0

local TopCorner = Instance.new("UICorner", Top)
TopCorner.CornerRadius = UDim.new(0,20)

-- Title
local Title = Instance.new("TextLabel")
Title.Parent = Top
Title.Size = UDim2.new(1,0,1,0)
Title.BackgroundTransparency = 1
Title.Text = "CYBER NEO HUB"
Title.Font = Enum.Font.GothamBold
Title.TextSize = 20
Title.TextColor3 = Theme.Accent

--// DRAGGABLE UI (CLEAN VERSION)
local dragging = false
local dragStart
local startPos

Top.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Main.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

--// FLOATING BALL (FIXED PROPERLY)
local Ball = Instance.new("ImageButton")
Ball.Parent = GUI
Ball.Size = UDim2.new(0,50,0,50)
Ball.Position = UDim2.new(0.05,0,0.5,0)
Ball.BackgroundColor3 = Theme.Accent
Ball.Image = "rbxassetid://6031225818"
Ball.ImageColor3 = Theme.Text
Ball.Visible = false
Ball.ZIndex = 1000
Ball.BorderSizePixel = 0

Instance.new("UICorner", Ball).CornerRadius = UDim.new(1,0)

-- Drag Ball
local bDragging = false
local bStart
local bPos
local moved = false

Ball.MouseButton1Down:Connect(function()
    bDragging = true
    moved = false
    bStart = UIS:GetMouseLocation()
    bPos = Ball.Position
end)

Ball.MouseButton1Up:Connect(function()
    if not moved then
        Main.Visible = true
        Ball.Visible = false
    end
    bDragging = false
end)

game:GetService("RunService").RenderStepped:Connect(function()
    if bDragging then
        local delta = UIS:GetMouseLocation() - bStart
        if math.abs(delta.X) > 4 or math.abs(delta.Y) > 4 then
            moved = true
        end
        
        Ball.Position = UDim2.new(
            bPos.X.Scale,
            bPos.X.Offset + delta.X,
            bPos.Y.Scale,
            bPos.Y.Offset + delta.Y
        )
    end
end)

--// MINIMIZE BUTTON
local Min = Instance.new("TextButton")
Min.Parent = Top
Min.Size = UDim2.new(0,40,0,40)
Min.Position = UDim2.new(1,-50,0.5,-20)
Min.Text = "-"
Min.Font = Enum.Font.GothamBold
Min.TextSize = 20
Min.BackgroundColor3 = Theme.BG
Min.TextColor3 = Theme.Text
Min.BorderSizePixel = 0
Instance.new("UICorner", Min).CornerRadius = UDim.new(0,10)

Min.MouseButton1Click:Connect(function()
    Main.Visible = false
    Ball.Visible = true
end)
