-- // LOGIC // --
local function Switch(name)
    for _, p in pairs(Pages) do p.Visible = false end
    Pages[name].Visible = true
end

-- Sidebar Navigation Setup
local function Nav(txt, icon, page)
    local b = Instance.new("TextButton", NavHolder)
    b.Size = UDim2.new(0, 50, 0, 50)
    b.BackgroundColor3 = Theme.Main
    b.Text = icon
    b.TextSize = 25
    b.TextColor3 = Theme.SubText
    Instance.new("UICorner", b)
    local s = Instance.new("UIStroke", b)
    s.Color = Theme.Accent
    s.Transparency = 0.8

    b.MouseButton1Click:Connect(function() 
        Switch(page) 
        for _, v in pairs(NavHolder:GetChildren()) do
            if v:IsA("TextButton") then v.TextColor3 = Theme.SubText end
        end
        b.TextColor3 = Theme.Accent
    end)
end

Nav("Search", "🔍", "Search")
Nav("Add", "➕", "Add")
Nav("Runner", "⌨️", "Runner")
Nav("Saved", "💾", "Saved")

-- // SAVED LIST ENGINE // --
local P_Saved = NewPage("Saved")
local Scroll = Instance.new("ScrollingFrame", P_Saved)
Scroll.Size = UDim2.new(0.94, 0, 0.9, 0)
Scroll.Position = UDim2.new(0.03, 0, 0.05, 0)
Scroll.BackgroundTransparency = 1
Scroll.ScrollBarThickness = 2
local SLayout = Instance.new("UIListLayout", Scroll)
SLayout.Padding = UDim.new(0, 10)

local function LoadScripts()
    for _, v in pairs(Scroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    local files = listfiles(MAIN_FOLDER)
    for _, path in pairs(files) do
        local name = path:gsub(MAIN_FOLDER.."/", "")
        local frame = Instance.new("Frame", Scroll)
        frame.Size = UDim2.new(1, 0, 0, 60)
        frame.BackgroundColor3 = Theme.Sidebar
        Instance.new("UICorner", frame)
        
        local label = Instance.new("TextLabel", frame)
        label.Text = "  " .. name
        label.Size = UDim2.new(0.6, 0, 1, 0)
        label.TextColor3 = Theme.Text
        label.BackgroundTransparency = 1
        label.TextXAlignment = "Left"
        label.Font = Enum.Font.Gotham

        local r = MakeNeoButton(frame, "RUN", Theme.Green)
        r.Size = UDim2.new(0, 70, 0.6, 0); r.Position = UDim2.new(0.65, 0, 0.2, 0)
        r.MouseButton1Click:Connect(function() loadstring(readfile(path))() end)

        local d = MakeNeoButton(frame, "DEL", Theme.Red)
        d.Size = UDim2.new(0, 70, 0.6, 0); d.Position = UDim2.new(0.82, 0, 0.2, 0)
        d.MouseButton1Click:Connect(function()
            delfile(path)
            LoadScripts()
        end)
    end
end

-- // FUNCTIONALITY // --
b_Execute.MouseButton1Click:Connect(function() loadstring(CodeEditor.Text)() end)
b_Clear.MouseButton1Click:Connect(function() CodeEditor.Text = "" end)
b_Trans.MouseButton1Click:Connect(function() AddCode.Text = CodeEditor.Text; Switch("Add") end)
b_FinalSave.MouseButton1Click:Connect(function()
    if AddName.Text ~= "" then
        writefile(MAIN_FOLDER.."/"..AddName.Text, AddCode.Text)
        AddName.Text = ""; AddCode.Text = ""
        LoadScripts(); Switch("Saved")
    end
end)

-- Toggle Minimize
local MinBtn = MakeNeoButton(Sidebar, "CLOSE", Theme.Red)
MinBtn.Size = UDim2.new(0.8, 0, 0.08, 0)
MinBtn.Position = UDim2.new(0.1, 0, 0.88, 0)
MinBtn.MouseButton1Click:Connect(function()
    Main.Visible = false
    BallFrame.Visible = true
end)

Ball.MouseButton1Click:Connect(function()
    Main.Visible = true
    BallFrame.Visible = false
end)

Switch("Runner")
print("Cyber-Neo Dashboard Initialized.")
