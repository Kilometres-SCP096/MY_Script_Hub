local function RefreshSavedScripts()
    for _, child in pairs(SavedScroll:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    local files = listfiles(MAIN_FOLDER)
    
    for _, filepath in pairs(files) do
        local filename = filepath:gsub(MAIN_FOLDER.."/", "")
        
        local scriptCard = Instance.new("Frame", SavedScroll)
        scriptCard.Size = UDim2.new(1, -5, 0, 65)
        scriptCard.BackgroundColor3 = Theme.Surface
        scriptCard.BorderSizePixel = 0
        
        CreateCorner(scriptCard, 8)
        CreateStroke(scriptCard, Theme.Border, 1, 0.6)
        
        local scriptIcon = Instance.new("ImageLabel", scriptCard)
        scriptIcon.Size = UDim2.new(0, 40, 0, 40)
        scriptIcon.Position = UDim2.new(0, 12, 0.5, -20)
        scriptIcon.BackgroundColor3 = Theme.Primary
        scriptIcon.Image = "rbxassetid://6034287594"
        scriptIcon.ImageColor3 = Theme.Text
        scriptIcon.BorderSizePixel = 0
        
        CreateCorner(scriptIcon, 6)
        
        local scriptName = Instance.new("TextLabel", scriptCard)
        scriptName.Size = UDim2.new(0.5, 0, 1, 0)
        scriptName.Position = UDim2.new(0, 60, 0, 0)
        scriptName.BackgroundTransparency = 1
        scriptName.Font = Enum.Font.GothamBold
        scriptName.Text = filename
        scriptName.TextColor3 = Theme.Text
        scriptName.TextSize = 13
        scriptName.TextXAlignment = "Left"
        scriptName.TextTruncate = "AtEnd"
        
        local runBtn = CreateButton(scriptCard, "▶", function()
            local code = readfile(filepath)
            loadstring(code)()
        end, "Success")
        runBtn.Size = UDim2.new(0, 50, 0, 35)
        runBtn.Position = UDim2.new(1, -120, 0.5, -17.5)
        
        local deleteBtn = CreateButton(scriptCard, "🗑", function()
            local popup = Instance.new("Frame", ScreenGui)
            popup.Size = UDim2.new(0, 300, 0, 150)
            popup.Position = UDim2.new(0.5, -150, 0.5, -75)
            popup.BackgroundColor3 = Theme.Surface
            popup.BorderSizePixel = 0
            popup.ZIndex = 100
            
            CreateCorner(popup, 10)
            CreateStroke(popup, Theme.Danger, 2, 0.5)
            CreateShadow(popup)
            
            local popupTitle = Instance.new("TextLabel", popup)
            popupTitle.Size = UDim2.new(1, 0, 0, 40)
            popupTitle.BackgroundTransparency = 1
            popupTitle.Font = Enum.Font.GothamBold
            popupTitle.Text = "⚠ CONFIRM DELETE"
            popupTitle.TextColor3 = Theme.Danger
            popupTitle.TextSize = 14
            
            local popupText = Instance.new("TextLabel", popup)
            popupText.Size = UDim2.new(1, -20, 0, 40)
            popupText.Position = UDim2.new(0, 10, 0, 45)
            popupText.BackgroundTransparency = 1
            popupText.Font = Enum.Font.Gotham
            popupText.Text = "Delete '" .. filename .. "'?"
            popupText.TextColor3 = Theme.Text
            popupText.TextSize = 12
            popupText.TextWrapped = true
            
            local yesBtn = CreateButton(popup, "YES", function()
                delfile(filepath)
                popup:Destroy()
                RefreshSavedScripts()
            end, "Danger")
            yesBtn.Size = UDim2.new(0.4, 0, 0, 35)
            yesBtn.Position = UDim2.new(0.1, 0, 1, -45)
            
            local noBtn = CreateButton(popup, "NO", function()
                popup:Destroy()
            end, "Secondary")
            noBtn.Size = UDim2.new(0.4, 0, 0, 35)
            noBtn.Position = UDim2.new(0.5, 0, 1, -45)
        end, "Danger")
        deleteBtn.Size = UDim2.new(0, 50, 0, 35)
        deleteBtn.Position = UDim2.new(1, -60, 0.5, -17.5)
    end
end

