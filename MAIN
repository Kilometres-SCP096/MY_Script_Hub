	renderFiles()
	renderSearch(SearchBox.Text)
	toast("Refreshed", "File list updated.", C.SUCCESS)
end)

--==================================================
-- MANAGE PAGE
--==================================================
local ManageWrap = make("Frame", {
	BackgroundTransparency = 1,
	Size = UDim2.new(1, 0, 1, 0),
	ZIndex = 10,
}, ManagePage)

local ManageTitle = label(ManageWrap, "Create or overwrite a file.", 13, C.MUTED, false)
ManageTitle.Size = UDim2.new(1, -4, 0, 18)
ManageTitle.ZIndex = 12

local NameBox = input(ManageWrap, "filename.lua", false, 40)
NameBox.Position = UDim2.new(0, 0, 0, 24)
NameBox.Size = UDim2.new(1, 0, 0, 40)
NameBox.ZIndex = 20

local CodeBox = input(ManageWrap, "Paste code here...", true, 132)
CodeBox.Position = UDim2.new(0, 0, 0, 74)
CodeBox.Size = UDim2.new(1, 0, 0, 132)
CodeBox.ZIndex = 20

local SaveBtn = button(ManageWrap, "Save / Overwrite", C.ACCENT, Color3.new(1,1,1), 14)
SaveBtn.Position = UDim2.new(0, 0, 0, 216)
SaveBtn.Size = UDim2.new(1, 0, 0, 38)
SaveBtn.ZIndex = 20

local ClearBtn = button(ManageWrap, "Clear", C.SURFACE2, C.TEXT, 14)
ClearBtn.Position = UDim2.new(0, 0, 0, 260)
ClearBtn.Size = UDim2.new(1, 0, 0, 34)
ClearBtn.ZIndex = 20

SaveBtn.MouseButton1Click:Connect(function()
	local fileName = ensureLuaName(NameBox.Text)
	local code = CodeBox.Text or ""

	if fileName == "" then
		toast("Missing Name", "Enter a filename first.", C.DANGER)
		return
	end

	local path = folderPath .. fileName
	local ok, err = pcall(writefile, path, code)
	if ok then
		refreshCache()
		renderFiles()
		renderSearch(SearchBox.Text)
		toast("Saved", fileName, C.SUCCESS)
	else
		toast("Save Failed", tostring(err), C.DANGER)
	end
end)

ClearBtn.MouseButton1Click:Connect(function()
	NameBox.Text = ""
	CodeBox.Text = ""
	toast("Cleared", "Fields reset.", C.SUCCESS)
end)

--==================================================
-- NAV HOOKS
--==================================================
SearchNav.MouseButton1Click:Connect(function()
	switchPage(SearchPage, "Search")
	renderSearch(SearchBox.Text)
end)

FilesNav.MouseButton1Click:Connect(function()
	switchPage(FilesPage, "Files")
end)

ManageNav.MouseButton1Click:Connect(function()
	switchPage(ManagePage, "Manage")
end)

RefreshHeaderBtn.MouseButton1Click:Connect(function()
	refreshCache()
	renderFiles()
	renderSearch(SearchBox.Text)
	toast("Refreshed", "All lists updated.", C.SUCCESS)
end)

--==================================================
-- STARTUP
--==================================================
refreshCache()
renderSearch("")
renderFiles()
switchPage(SearchPage, "Search")
toast("Ready", "Hub loaded successfully.", C.SUCCESS)
