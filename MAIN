local ExecuteButton = CreateButton(ButtonContainer, "▶ EXECUTE", function()
    local success, err = pcall(function()
        loadstring(CodeEditor.Text)()
    end)
    if not success then
        warn("⚠ Execution Error:", err)
        
        -- Error notification
        local errNotif = Instance.new("Frame", ScreenGui)
        errNotif.Size = UDim2.new(0, 300, 0, 70)
        errNotif.Position = UDim2.new(0.5, -150, 0, -80)
        errNotif.BackgroundColor3 = Theme.Danger
        errNotif.BorderSizePixel = 0
        errNotif.ZIndex = 10000
        
        CreateCorner(errNotif, 10)
        CreateStroke(errNotif, Theme.Danger, 2, 0.3)
        
        local errText = Instance.new("TextLabel", errNotif)
        errText.Size = UDim2.new(1, -20, 1, 0)
        errText.Position = UDim2.new(0, 10, 0, 0)
        errText.BackgroundTransparency = 1
        errText.Text = "⚠ ERROR\n" .. tostring(err):sub(1, 50)
        errText.TextColor3 = Color3.new(1,1,1)
        errText.Font = Enum.Font.GothamBold
        errText.TextSize = 11
        errText.TextWrapped = true
        
        TweenService:Create(errNotif, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Position = UDim2.new(0.5, -150, 0, 20)}):Play()
        wait(3)
        TweenService:Create(errNotif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -150, 0, -80)}):Play()
        wait(0.3)
        errNotif:Destroy()
    else
        -- Success notification
        local sucNotif = Instance.new("Frame", ScreenGui)
        sucNotif.Size = UDim2.new(0, 250, 0, 60)
        sucNotif.Position = UDim2.new(0.5, -125, 0, -70)
        sucNotif.BackgroundColor3 = Theme.Success
        sucNotif.BorderSizePixel = 0
        sucNotif.ZIndex = 10000
        
        CreateCorner(sucNotif, 10)
        
        local sucText = Instance.new("TextLabel", sucNotif)
        sucText.Size = UDim2.new(1, 0, 1, 0)
        sucText.BackgroundTransparency = 1
        sucText.Text = "✓ Script Executed!"
