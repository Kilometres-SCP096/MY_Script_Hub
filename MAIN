local function toast(title, message, tint)
	ToastTitle.Text = title or "Status"
	ToastTitle.TextColor3 = tint or C.ACCENT
	ToastBody.Text = message or ""
	Toast.Visible = true
	task.delay(2.2, function()
		if Toast then
			Toast.Visible = false
		end
	end)
end

