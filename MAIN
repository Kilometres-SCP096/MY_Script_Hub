-- ========================================
-- PAGE SYSTEM
-- ========================================
local Pages = {}

local function Page(n)
    local p = Instance.new("Frame", Cont)
    p.Name = n
    p.Size = UDim2.new(1, 0, 1, 0)
    p.BackgroundTransparency = 1
    p.Visible = false
    Pages[n] = p
    return p
end

local function Switch(n)
    for _, p in pairs(Pages) do
        p.Visible = false
    end
    if Pages[n] then
        Pages[n].Visible = true
    end
end

-- ========================================
-- PAGE HEADER HELPER
-- ========================================
local function PageHeader(parent, icon, title, subtitle)
    local hFrame = Instance.new("Frame", parent)
    hFrame.Size = UDim2.new(1, 0, 0, 38)
    hFrame.Position = UDim2.new(0, 0, 0, 0)
    hFrame.BackgroundTransparency = 1

    local ico = Instance.new("TextLabel", hFrame)
    ico.Size = UDim2.new(0, 30, 1, 0)
    ico.BackgroundTransparency = 1
    ico.Text = icon
    ico.TextSize = 22
    ico.Font = Enum.Font.GothamBold
    ico.TextColor3 = Theme.Accent

    local ttl = Instance.new("TextLabel", hFrame)
    ttl.Size = UDim2.new(1, -35, 0, 22)
    ttl.Position = UDim2.new(0, 35, 0, 0)
    ttl.BackgroundTransparency = 1
    ttl.Text = title
    ttl.TextSize = 16
    ttl.Font = Enum.Font.GothamBold
    ttl.TextColor3 = Theme.Text
    ttl.TextXAlignment = Enum.TextXAlignment.Left

    local sub = Instance.new("TextLabel", hFrame)
    sub.Size = UDim2.new(1, -35, 0, 16)
    sub.Position = UDim2.new(0, 35, 0, 22)
    sub.BackgroundTransparency = 1
    sub.Text = subtitle
    sub.TextSize = 11
    sub.Font = Enum.Font.Gotham
    sub.TextColor3 = Theme.TextDim
    sub.TextXAlignment = Enum.TextXAlignment.Left

    -- Divider line under header
    local line = Instance.new("Frame", parent)
    line.Size = UDim2.new(1, 0, 0, 1)
    line.Position = UDim2.new(0, 0, 0, 42)
    line.BackgroundColor3 = Theme.Border
    line.BorderSizePixel = 0

    return hFrame
end

