local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local folderPath = "My_Script_Hub/"
if not isfolder(folderPath) then makefolder(folderPath) end

-- // 1. NUKE OLD UI // --
for _, old in pairs(CoreGui:GetChildren()) do
    if old.Name == "Kilometres_Final_Fix" then old:Destroy() end
end

-- // 2. SETUP // --
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "Kilometres_Final_Fix"
ScreenGui.DisplayOrder = 999 -- Force to the very top layer
ScreenGui.IgnoreGuiInset = true

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 450, 0, 300)
MainFrame.Position = UDim2.new(0.5, -225, 0.5, -150)
MainFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
MainFrame.ZIndex = 1
MainFrame.ClipsDescendants = false -- FIX: Don't hide stuff!

Instance.new("UICorner", MainFrame)
local MainStroke = Instance.new("UIStroke", MainFrame)
MainStroke.Color = Color3.fromRGB(138, 43, 226)
MainStroke.Thickness = 2

-- // 3. SIDEBAR (The Navigation) // --
local Sidebar = Instance.new("Frame", MainFrame)
Sidebar.Size = UDim2.new(0, 110, 1, -20)
Sidebar.Position = UDim2.new(0, 10, 0, 10)
Sidebar.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Sidebar.ZIndex = 2
Instance.new("UICorner", Sidebar)

local SideLayout = Instance.new("UIListLayout", Sidebar)
SideLayout.Padding = UDim.new(0, 5)
SideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

-- // 4. PAGE HOLDER // --
local Pages = Instance.new("Frame", MainFrame)
Pages.Size = UDim2.new(1, -140, 1, -20)
Pages.Position = UDim2.new(0, 130, 0, 10)
Pages.BackgroundTransparency = 1
Pages.ZIndex = 2

local function CreatePage(name, isDefault)
    local Page = Instance.new("ScrollingFrame", Pages)
    Page.Name = name .. "_Page"
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.Visible = isDefault or false
    Page.BackgroundTransparency = 1
    Page.ScrollBarThickness = 3
    Page.ZIndex = 3
    Page.CanvasSize = UDim2.new(0, 0, 5, 0) -- Pre-set large canvas
    Page.AutomaticCanvasSize = Enum.AutomaticCanvasSize.Y
    
    local Layout = Instance.new("UIListLayout", Page)
    Layout.Padding = UDim.new(0, 10)
    
    local TabBtn = Instance.new("TextButton", Sidebar)
    TabBtn.Size = UDim2.new(0.9, 0, 0, 35)
    TabBtn.Text = name
    TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    TabBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    TabBtn.ZIndex = 10 -- High ZIndex to ensure it shows
    Instance.new("UICorner", TabBtn)
    
    TabBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages:GetChildren()) do p.Visible = false end
        Page.Visible = true
    end)
    
    return Page
end

local SearchPage = CreatePage("Search", true)
local ManagePage = CreatePage("Manage")
local FilesPage = CreatePage("Files")

-- // 5. ADDING THE ELEMENTS (Guaranteed Visible) // --

-- [SEARCH PAGE]
local SBox = Instance.new("TextBox", SearchPage)
SBox.Size = UDim2.new(1, -10, 0, 40)
SBox.PlaceholderText = "Type Script Name..."
SBox.Text = ""
SBox.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
SBox.TextColor3 = Color3.fromRGB(255, 255, 255)
SBox.ZIndex = 20
Instance.new("UICorner", SBox)

-- [FILES PAGE]
local function Refresh()
    for _, v in pairs(FilesPage:GetChildren()) do
        if v:IsA("TextButton") and v.Name ~= "Ref" then v:Destroy() end
    end
    
    local files = listfiles(folderPath)
    for _, file in pairs(files) do
        local name = file:gsub(folderPath, "")
        local B = Instance.new("TextButton", FilesPage)
        B.Size = UDim2.new(1, -10, 0, 40)
        B.Text = "  ▶️ " .. name
        B.TextColor3 = Color3.fromRGB(200, 200, 200)
        B.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        B.TextXAlignment = Enum.TextXAlignment.Left
        B.ZIndex = 20
        Instance.new("UICorner", B)
        
        B.MouseButton1Click:Connect(function()
            loadstring(readfile(file))()
        end)
    end
end

local Ref = Instance.new("TextButton", FilesPage)
Ref.Name = "Ref"
Ref.Size = UDim2.new(1, -10, 0, 40)
Ref.Text = "🔄 REFRESH SCRIPTS"
Ref.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
Ref.TextColor3 = Color3.fromRGB(255, 255, 255)
Ref.ZIndex = 20
Instance.new("UICorner", Ref)
Ref.MouseButton1Click:Connect(Refresh)

-- // 6. RAYFIELD TOGGLE BUTTON // --
local Toggle = Instance.new("TextButton", ScreenGui)
Toggle.Size = UDim2.new(0, 50, 0, 50)
Toggle.Position = UDim2.new(0, 10, 0.5, -25)
Toggle.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Toggle.Text = "K"
Toggle.TextColor3 = Color3.fromRGB(138, 43, 226)
Toggle.TextSize = 25
Toggle.ZIndex = 999
Toggle.Draggable = true
Instance.new("UICorner", Toggle).CornerRadius = UDim.new(1, 0)
local TStroke = Instance.new("UIStroke", Toggle)
TStroke.Color = Color3.fromRGB(138, 43, 226)

Toggle.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
end)

-- // DRAG SYSTEM // --
MainFrame.Active = true
MainFrame.Draggable = true

Refresh() -- Load those 19 scripts
