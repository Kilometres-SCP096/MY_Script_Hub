local SearchWrap = make("Frame", {
	BackgroundTransparency = 1,
	Size = UDim2.new(1, 0, 1, 0),
	ZIndex = 10,
}, SearchPage)

local SearchBox = input(SearchWrap, "Search script name...", false, 40)
SearchBox.Size = UDim2.new(1, -2, 0, 40)
SearchBox.ZIndex = 20

local SearchHint = label(SearchWrap, "Search only filters file names. No auto-run here.", 12, C.MUTED, false)
SearchHint.Position = UDim2.new(0, 2, 0, 46)
SearchHint.Size = UDim2.new(1, -4, 0, 16)
SearchHint.ZIndex = 12

local SearchResults = make("ScrollingFrame", {
	BackgroundTransparency = 1,
	Position = UDim2.new(0, 0, 0, 68),
	Size = UDim2.new(1, 0, 1, -68),
	BorderSizePixel = 0,
	ScrollBarThickness = 4,
	AutomaticCanvasSize = Enum.AutomaticSize.Y,
	CanvasSize = UDim2.new(0, 0, 0, 0),
	ZIndex = 10,
}, SearchWrap)
pad(SearchResults, 0, 0, 0, 2)
make("UIListLayout", {
	Padding = UDim.new(0, 8),
	SortOrder = Enum.SortOrder.LayoutOrder,
}, SearchResults)

local function renderSearch(query)
	clearFrame(SearchResults)
	query = tostring(query or ""):gsub("^%s+", ""):gsub("%s+$", ""):lower()

	if query == "" then
		local empty = label(SearchResults, "Type a script name to filter results.", 13, C.MUTED, false)
		empty.Size = UDim2.new(1, -4, 0, 24)
		empty.ZIndex = 12
		return
	end

	local matches = 0
	for _, file in ipairs(FileCache) do
		-- search only by script name, not content
		if file.name:lower():find(query, 1, true) then
			createRow(SearchResults, file)
			matches += 1
		end
	end

	if matches == 0 then
		local empty = label(SearchResults, "No matching script names found.", 13, C.MUTED, false)
		empty.Size = UDim2.new(1, -4, 0, 24)
		empty.ZIndex = 12
	end
end

SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
	renderSearch(SearchBox.Text)
end)

