SaveButton.MouseButton1Click:Connect(function()
    if NameInput.Text ~= "" and CodeInput.Text ~= "" then
        writefile(MAIN_FOLDER .. "/" .. NameInput.Text, CodeInput.Text)
        NameInput.Text = ""
        CodeInput.Text = ""
        
        local notif = Instance.new("Frame", ScreenGui)
        notif.Size = UDim2.new(0, 280, 0, 70)
        notif.Position = UDim2.new(0.5, -140, 0, -80)
        notif.BackgroundColor3 = Theme.Success
        notif.BorderSizePixel = 0
        notif.ZIndex = 10000
        
        CreateCorner(notif, 10)
        CreateStroke(notif, Theme.Success, 2, 0.3)
        
        local notifText = Instance.new("TextLabel", notif)
        notifText.Size = UDim2.new(1, 0, 1, 0)
        notifText.BackgroundTransparency = 1
        notifText.Text = "✓ Script Saved Successfully!"
        notifText.TextColor3 = Color3.new(1,1,1)
        notifText.Font = Enum.Font.GothamBold
        notifText.TextSize = 14
        
        TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Position = UDim2.new(0.5, -140, 0, 20)}):Play()
        wait(2.5)
        TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -140, 0, -80)}):Play()
        wait(0.3)
        notif:Destroy()
        
        RefreshSavedScripts()
        SwitchPage("Saved")
    else
        -- Warning notification
        local warnNotif = Instance.new("Frame", ScreenGui)
        warnNotif.Size = UDim2.new(0, 280, 0, 70)
        warnNotif.Position = UDim2.new(0.5, -140, 0, -80)
        warnNotif.BackgroundColor3 = Theme.Warning
        warnNotif.BorderSizePixel = 0
        warnNotif.ZIndex = 10000
        
        CreateCorner(warnNotif, 10)
        
        local warnText = Instance.new("TextLabel", warnNotif)
        warnText.Size = UDim2.new(1, 0, 1, 0)
        warnText.BackgroundTransparency = 1
        warnText.Text = "⚠ Please fill all fields!"
        warnText.TextColor3 = Color3.new(1,1,1)
        warnText.Font = Enum.Font.GothamBold
        warnText.TextSize = 14
        
        TweenService:Create(warnNotif, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Position = UDim2.new(0.5, -140, 0, 20)}):Play()
        wait(2)
        TweenService:Create(warnNotif, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -140, 0, -80)}):Play()
        wait(0.3)
        warnNotif:Destroy()
    end
end)

