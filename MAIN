if not isfolder(MAIN_FOLDER) then makefolder(MAIN_FOLDER) end
if not isfolder(ICON_FOLDER) then makefolder(ICON_FOLDER) end

-- // THEME COLOR PALETTE // --
local Theme = {
    Main = Color3.fromRGB(12, 10, 18),
    Sidebar = Color3.fromRGB(18, 15, 28),
    Accent = Color3.fromRGB(160, 100, 255),
    Glow = Color3.fromRGB(180, 130, 255),
    Text = Color3.fromRGB(240, 240, 240),
    SubText = Color3.fromRGB(150, 140, 180),
    Red = Color3.fromRGB(220, 60, 60),
    Green = Color3.fromRGB(60, 220, 120),
}

-- // UI START // --
local SG = Instance.new("ScreenGui", CoreGui)
SG.Name = "CyberNeo_Hub"

-- // UTILS // --
local function CreateShadow(parent)
    local s = Instance.new("ImageLabel", parent)
    s.AnchorPoint = Vector2.new(0.5, 0.5)
    s.Position = UDim2.new(0.5, 0, 0.5, 0)
    s.Size = UDim2.new(1, 40, 1, 40)
    s.BackgroundTransparency = 1
    s.Image = "rbxassetid://1316045217"
    s.ImageColor3 = Color3.new(0, 0, 0)
    s.ImageTransparency = 0.5
    s.ZIndex = parent.ZIndex - 1
end

local function MakeNeoButton(parent, text, color)
    local btn = Instance.new("TextButton", parent)
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.Font = Enum.Font.GothamBold
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextSize = 14
    local c = Instance.new("UICorner", btn)
    local s = Instance.new("UIStroke", btn)
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Color = Theme.Glow
    s.Thickness = 1.5
    s.Transparency = 0.6
    
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = color:Lerp(Color3.new(1,1,1), 0.2)}):Play()
        TweenService:Create(s, TweenInfo.new(0.3), {Transparency = 0}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = color}):Play()
        TweenService:Create(s, TweenInfo.new(0.3), {Transparency = 0.6}):Play()
    end)
    return btn
end

-- // FLOATING BALL (MOVABLE) // --
local BallFrame = Instance.new("Frame", SG)
BallFrame.Size = UDim2.new(0, 65, 0, 65)
BallFrame.Position = UDim2.new(0.05, 0, 0.5, 0)
BallFrame.BackgroundTransparency = 1
BallFrame.Visible = false

local Ball = Instance.new("ImageButton", BallFrame)
Ball.Size = UDim2.new(1, 0, 1, 0)
Ball.BackgroundColor3 = Theme.Sidebar
Ball.Image = "rbxassetid://6031225818" -- Tech Core Icon
Ball.ImageColor3 = Theme.Accent
Instance.new("UICorner", Ball).CornerRadius = UDim.new(1, 0)
local BallStroke = Instance.new("UIStroke", Ball)
BallStroke.Color = Theme.Accent
BallStroke.Thickness = 2

-- Smooth Drag Logic
local dragToggle, dragStart, startPos
Ball.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragToggle = true
        dragStart = input.Position
        startPos = BallFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragToggle and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        BallFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragToggle = false end
end)

