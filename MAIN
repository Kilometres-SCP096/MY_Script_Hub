local SearchPage = CreatePage("Search")

local SearchTitle = Instance.new("TextLabel", SearchPage)
SearchTitle.Size = UDim2.new(1, 0, 0, 30)
SearchTitle.BackgroundTransparency = 1
SearchTitle.Font = Enum.Font.GothamBold
SearchTitle.Text = "◉ SCRIPT SEARCH"
SearchTitle.TextColor3 = Theme.Accent
SearchTitle.TextSize = 14
SearchTitle.TextXAlignment = "Left"

local SearchInput = CreateTextBox(SearchPage, "Search scripts...")
SearchInput.Size = UDim2.new(0.7, 0, 0, 45)
SearchInput.Position = UDim2.new(0, 0, 0, 40)

local SearchModeBtn = CreateButton(SearchPage, "MODE: LOCAL", nil, "Secondary")
SearchModeBtn.Size = UDim2.new(0.28, 0, 0, 45)
SearchModeBtn.Position = UDim2.new(0.72, 0, 0, 40)

local searchMode = "local"
SearchModeBtn.MouseButton1Click:Connect(function()
    if searchMode == "local" then
        searchMode = "online"
        SearchModeBtn.Text = "MODE: ONLINE"
        TweenProperty(SearchModeBtn, "BackgroundColor3", Theme.Warning)
    else
        searchMode = "local"
        SearchModeBtn.Text = "MODE: LOCAL"
        TweenProperty(SearchModeBtn, "BackgroundColor3", Theme.Secondary)
    end
end)

local SearchResults = Instance.new("ScrollingFrame", SearchPage)
SearchResults.Size = UDim2.new(1, 0, 1, -100)
SearchResults.Position = UDim2.new(0, 0, 0, 95)
SearchResults.BackgroundTransparency = 1
SearchResults.BorderSizePixel = 0
SearchResults.ScrollBarThickness = 4
SearchResults.CanvasSize = UDim2.new(0, 0, 0, 0)
SearchResults.AutomaticCanvasSize = "Y"

local SearchLayout = Instance.new("UIListLayout", SearchResults)
SearchLayout.Padding = UDim.new(0, 8)

SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
    for _, child in pairs(SearchResults:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    
    local query = SearchInput.Text:lower()
    if query == "" then return end
    
    if searchMode == "local" then
        local files = listfiles(MAIN_FOLDER)
        for _, path in pairs(files) do
            local name = path:gsub(MAIN_FOLDER.."/", "")
            if name:lower():find(query) then
                local result = Instance.new("Frame", SearchResults)
                result.Size = UDim2.new(1, -5, 0, 50)
                result.BackgroundColor3 = Theme.Surface
                
                CreateCorner(result, 6)
                
                local label = Instance.new("TextLabel", result)
                label.Size = UDim2.new(0.7, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Text = "  " .. name
                label.TextColor3 = Theme.Text
                label.TextXAlignment = "Left"
                label.Font = Enum.Font.Gotham
                
                local open = CreateButton(result, "OPEN", function()
                    CodeEditor.Text = readfile(path)
                    SwitchPage("Runner")
                end, "Primary")
                open.Size = UDim2.new(0, 80, 0.7, 0)
                open.Position = UDim2.new(1, -90, 0.15, 0)
            end
        end
    end
end)

-- ========================================
-- [[ NAVIGATION ICONS - FIXED NON-SCROLLABLE ]]
-- ========================================

local navButtons = {}

local function CreateNavIcon(iconId, tooltip, targetPage, order)
    local btn = CreateIconButton(NavContainer, iconId)
    btn.Size = UDim2.new(0, 50, 0, 50)
    btn.LayoutOrder = order
    
    btn.MouseButton1Click:Connect(function()
        SwitchPage(targetPage)
        
        for _, navBtn in pairs(navButtons) do
            TweenProperty(navBtn, "BackgroundColor3", Theme.Surface)
            TweenProperty(navBtn, "ImageColor3", Theme.TextDim)
        end
        
        TweenProperty(btn, "BackgroundColor3", Theme.Primary:Lerp(Theme.Surface, 0.5))
        TweenProperty(btn, "ImageColor3", Theme.Accent)
    end)
    
    table.insert(navButtons, btn)
    return btn
end

CreateNavIcon("rbxassetid://6031154871", "Search", "Search", 1)
CreateNavIcon("rbxassetid://6035043449", "Add Script", "Add", 2)
CreateNavIcon("rbxassetid://6034823313", "Script Runner", "Runner", 3)
CreateNavIcon("rbxassetid://6031155054", "Saved Scripts", "Saved", 4)

-- ========================================
-- [[ FUNCTIONALITY CONNECTIONS ]]
-- ========================================

TransferButton.MouseButton1Click:Connect(function()
    CodeInput.Text = CodeEditor.Text
    SwitchPage("Add")
end)

SaveButton.MouseButton1Click:Connect(function()
    if NameInput.Text ~= "" and CodeInput.Text ~= "" then
        writefile(MAIN_FOLDER .. "/" .. NameInput.Text, CodeInput.Text)
        NameInput.Text = ""
        CodeInput.Text = ""
        
        local notif = Instance.new("Frame", ScreenGui)
        notif.Size = UDim2.new(0, 250, 0, 60)
        notif.Position = UDim2.new(1, -270, 0, 20)
        notif.BackgroundColor3 = Theme.Success
        notif.BorderSizePixel = 0
        notif.ZIndex = 1000
        
        CreateCorner(notif, 8)
        
        local notifText = Instance.new("TextLabel", notif)
        notifText.Size = UDim2.new(1, 0, 1, 0)
        notifText.BackgroundTransparency = 1
        notifText.Text = "✓ Script Saved!"
        notifText.TextColor3 = Color3.new(1,1,1)
        notifText.Font = Enum.Font.GothamBold
        notifText.TextSize = 14
        
        TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(1, -270, 0, 20)}):Play()
        wait(2)
        TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(1, 0, 0, 20)}):Play()
        wait(0.3)
        notif:Destroy()
        
        RefreshSavedScripts()
        SwitchPage("Saved")
    end
end)

