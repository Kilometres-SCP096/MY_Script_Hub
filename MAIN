-- ========================================
-- [[ FLOATING TOGGLE BALL - COMPLETELY REWRITTEN ]]
-- ========================================

local FloatingBall = Instance.new("ImageButton", ScreenGui)
FloatingBall.Name = "FloatingBall"
FloatingBall.Size = UDim2.new(0, 70, 0, 70)
FloatingBall.Position = UDim2.new(0.05, 0, 0.45, 0)
FloatingBall.BackgroundColor3 = Theme.Primary
FloatingBall.Image = "rbxassetid://6031225818"
FloatingBall.ImageColor3 = Theme.Text
FloatingBall.BorderSizePixel = 0
FloatingBall.Visible = false
FloatingBall.ZIndex = 10000

CreateCorner(FloatingBall, 35)
local ballStroke = CreateStroke(FloatingBall, Theme.Glow, 3, 0.3)
CreateGradient(FloatingBall, 45, Theme.Primary, Theme.Secondary)

-- Pulsing Animation
spawn(function()
    while true do
        if FloatingBall.Visible then
            ballStroke.Thickness = 3 + math.sin(tick() * 3) * 1
            ballStroke.Transparency = 0.3 + math.sin(tick() * 3) * 0.2
        end
        RunService.RenderStepped:Wait()
    end
end)

-- ULTRA FIXED DRAGGING SYSTEM
local isDragging = false
local dragStartPos = nil
local ballStartPos = nil
local clickDetected = false

FloatingBall.MouseButton1Down:Connect(function()
    clickDetected = true
    isDragging = false
    dragStartPos = UserInputService:GetMouseLocation()
    ballStartPos = FloatingBall.Position
    
    wait(0.1)
    if clickDetected then
        isDragging = true
    end
end)

FloatingBall.MouseButton1Up:Connect(function()
    if not isDragging and clickDetected then
        -- Click action - show main UI
        MainFrame.Visible = true
        FloatingBall.Visible = false
    end
    isDragging = false
    clickDetected = false
end)

RunService.RenderStepped:Connect(function()
    if isDragging then
        local currentMousePos = UserInputService:GetMouseLocation()
        local delta = currentMousePos - dragStartPos
        
        FloatingBall.Position = UDim2.new(
            ballStartPos.X.Scale,
            ballStartPos.X.Offset + delta.X,
            ballStartPos.Y.Scale,
            ballStartPos.Y.Offset + delta.Y
        )
    end
end)

