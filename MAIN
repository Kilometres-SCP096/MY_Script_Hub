SearchSubtitle.TextColor3 = Theme.TextDim
SearchSubtitle.TextSize = 11
SearchSubtitle.TextXAlignment = "Left"

local SearchInput = CreateTextBox(SearchPage, "Search scripts...")
SearchInput.Size = UDim2.new(0.68, 0, 0, 50)
SearchInput.Position = UDim2.new(0, 0, 0, 65)
SearchInput.TextSize = 13

local SearchModeBtn = CreateButton(SearchPage, "MODE: LOCAL", nil, "Secondary")
SearchModeBtn.Size = UDim2.new(0.3, 0, 0, 50)
SearchModeBtn.Position = UDim2.new(0.7, 0, 0, 65)
SearchModeBtn.TextSize = 12

local searchMode = "local"
SearchModeBtn.MouseButton1Click:Connect(function()
    if searchMode == "local" then
        searchMode = "online"
        SearchModeBtn.Text = "MODE: ONLINE"
        TweenProperty(SearchModeBtn, "BackgroundColor3", Theme.Warning)
    else
        searchMode = "local"
        SearchModeBtn.Text = "MODE: LOCAL"
        TweenProperty(SearchModeBtn, "BackgroundColor3", Theme.Secondary)
    end
end)

local SearchResults = Instance.new("ScrollingFrame", SearchPage)
SearchResults.Size = UDim2.new(1, 0, 1, -130)
SearchResults.Position = UDim2.new(0, 0, 0, 125)
SearchResults.BackgroundTransparency = 1
SearchResults.BorderSizePixel = 0
SearchResults.ScrollBarThickness = 5
SearchResults.ScrollBarImageColor3 = Theme.Primary
SearchResults.CanvasSize = UDim2.new(0, 0, 0, 0)
SearchResults.AutomaticCanvasSize = "Y"

local SearchLayout = Instance.new("UIListLayout", SearchResults)
SearchLayout.Padding = UDim.new(0, 10)

SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
    for _, child in pairs(SearchResults:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    
    local query = SearchInput.Text:lower()
    if query == "" then return end
    
    if searchMode == "local" then
        local files = listfiles(MAIN_FOLDER)
        local found = false
        
        for _, path in pairs(files) do
            local name = path:gsub(MAIN_FOLDER.."/", "")
            if name:lower():find(query) then
                found = true
                
                local result = Instance.new("Frame", SearchResults)
                result.Size = UDim2.new(1, -8, 0, 55)
                result.BackgroundColor3 = Theme.Surface
                
                CreateCorner(result, 10)
                CreateStroke(result, Theme.Border, 1, 0.7)
                
                local icon = Instance.new("ImageLabel", result)
                icon.Size = UDim2.new(0, 35, 0, 35)
                icon.Position = UDim2.new(0, 12, 0.5, -17.5)
                icon.BackgroundColor3 = Theme.Primary
                icon.Image = "rbxassetid://6034287594"
                icon.ImageColor3 = Theme.Text
                icon.BorderSizePixel = 0
                CreateCorner(icon, 6)
                
                local label = Instance.new("TextLabel", result)
                label.Size = UDim2.new(0.6, 0, 1, 0)
                label.Position = UDim2.new(0, 55, 0, 0)
                label.BackgroundTransparency = 1
                label.Text = name
                label.TextColor3 = Theme.Text
                label.TextXAlignment = "Left"
                label.Font = Enum.Font.GothamBold
                label.TextSize = 12
                
                local open = CreateButton(result, "OPEN", function()
                    CodeEditor.Text = readfile(path)
                    SwitchPage("Runner")
                end, "Primary")
                open.Size = UDim2.new(0, 90, 0.65, 0)
                open.Position = UDim2.new(1, -100, 0.175, 0)
                open.TextSize = 12
            end
        end
        
        if not found then
            local noResult = Instance.new("TextLabel", SearchResults)
            noResult.Size = UDim2.new(1, 0, 0, 80)
            noResult.BackgroundTransparency = 1
            noResult.Font = Enum.Font.Gotham
            noResult.Text = "No scripts found matching '" .. query .. "'"
            noResult.TextColor3 = Theme.TextDim
            noResult.TextSize = 12
        end
    end
end)

