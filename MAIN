-- ========================================
-- THEME
-- ========================================
local Theme = {
    Background = Color3.fromRGB(10, 8, 15),
    Sidebar = Color3.fromRGB(18, 14, 25),
    Surface = Color3.fromRGB(25, 20, 35),
    Primary = Color3.fromRGB(140, 80, 255),
    Secondary = Color3.fromRGB(100, 50, 200),
    Accent = Color3.fromRGB(180, 120, 255),
    Success = Color3.fromRGB(80, 200, 120),
    Danger = Color3.fromRGB(220, 80, 80),
    Warning = Color3.fromRGB(255, 180, 60),
    Text = Color3.fromRGB(245, 245, 250),
    TextDim = Color3.fromRGB(160, 150, 180),
    Border = Color3.fromRGB(60, 40, 100),
    Glow = Color3.fromRGB(200, 140, 255),
}

-- ========================================
-- UTILITIES
-- ========================================
local function Corner(p, r) local c = Instance.new("UICorner", p) c.CornerRadius = UDim.new(0, r or 12) return c end
local function Stroke(p, col, t, tr) local s = Instance.new("UIStroke", p) s.Color = col or Theme.Border s.Thickness = t or 1 s.Transparency = tr or 0.5 s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border return s end
local function Gradient(p, r, c1, c2) local g = Instance.new("UIGradient", p) g.Rotation = r or 90 g.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, c1 or Theme.Primary), ColorSequenceKeypoint.new(1, c2 or Theme.Secondary)}) return g end
local function Shadow(p) local s = Instance.new("ImageLabel", p) s.Name = "Shadow" s.BackgroundTransparency = 1 s.Image = "rbxassetid://1316045217" s.ImageColor3 = Color3.new(0,0,0) s.ImageTransparency = 0.7 s.Size = UDim2.new(1, 40, 1, 40) s.Position = UDim2.new(0, -20, 0, -20) s.ZIndex = math.max((p.ZIndex or 1) - 1, 1) return s end
local function Tween(obj, prop, val, dur) TweenService:Create(obj, TweenInfo.new(dur or 0.3, Enum.EasingStyle.Quad), {[prop] = val}):Play() end

local function Btn(parent, text, callback, style)
    style = style or "Primary"
    local b = Instance.new("TextButton", parent)
    b.BackgroundColor3 = Theme[style] or Theme.Primary
    b.BorderSizePixel = 0
    b.Font = Enum.Font.GothamBold
    b.Text = text
    b.TextColor3 = Theme.Text
    b.TextSize = 13
    b.AutoButtonColor = false
    Corner(b, 8)
    local s = Stroke(b, Theme.Glow, 1.5, 0.7)
    local oc = b.BackgroundColor3
    b.MouseEnter:Connect(function() Tween(b, "BackgroundColor3", oc:Lerp(Color3.new(1,1,1), 0.15)) Tween(s, "Transparency", 0.2) end)
    b.MouseLeave:Connect(function() Tween(b, "BackgroundColor3", oc) Tween(s, "Transparency", 0.7) end)
    b.MouseButton1Down:Connect(function() Tween(b, "BackgroundColor3", oc:Lerp(Color3.new(0,0,0), 0.2)) end)
    b.MouseButton1Up:Connect(function() Tween(b, "BackgroundColor3", oc) end)
    if callback then b.MouseButton1Click:Connect(callback) end
    return b
end

local function TBox(parent, placeholder, multiline)
    local t = Instance.new("TextBox", parent)
    t.BackgroundColor3 = Theme.Surface
    t.BorderSizePixel = 0
    t.Font = Enum.Font.Gotham
    t.PlaceholderText = placeholder or ""
    t.Text = ""
    t.TextColor3 = Theme.Text
    t.TextSize = 12
    t.ClearTextOnFocus = false
    t.MultiLine = multiline or false
    t.TextXAlignment = multiline and "Left" or "Center"
    t.TextYAlignment = multiline and "Top" or "Center"
    Corner(t, 8)
    Stroke(t, Theme.Border, 1, 0.6)
    local p = Instance.new("UIPadding", t)
    p.PaddingLeft = UDim.new(0, 10)
    p.PaddingRight = UDim.new(0, 10)
    p.PaddingTop = UDim.new(0, multiline and 10 or 0)
    p.PaddingBottom = UDim.new(0, multiline and 10 or 0)
    return t
end

local function IconBtn(parent, iconId, callback)
    local b = Instance.new("ImageButton", parent)
    b.BackgroundColor3 = Theme.Surface
    b.BorderSizePixel = 0
    b.Image = iconId
    b.ImageColor3 = Theme.TextDim
    b.AutoButtonColor = false
    Corner(b, 10)
    local s = Stroke(b, Theme.Border, 1.5, 0.8)
    b.MouseEnter:Connect(function() Tween(b, "ImageColor3", Theme.Accent) Tween(b, "BackgroundColor3", Theme.Surface:Lerp(Theme.Primary, 0.1)) Tween(s, "Transparency", 0.3) end)
    b.MouseLeave:Connect(function() Tween(b, "ImageColor3", Theme.TextDim) Tween(b, "BackgroundColor3", Theme.Surface) Tween(s, "Transparency", 0.8) end)
    if callback then b.MouseButton1Click:Connect(callback) end
    return b
end

