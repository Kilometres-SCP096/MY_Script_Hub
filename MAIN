local deleteTarget = nil

local function openDelete(path)
	deleteTarget = path
	PromptFile.Text = relName(path)
	Prompt.Visible = true
	Shade.Visible = true
end

local function closeDelete()
	deleteTarget = nil
	Prompt.Visible = false
	Shade.Visible = false
end

CancelDelete.MouseButton1Click:Connect(closeDelete)
Shade.MouseButton1Click:Connect(closeDelete)

ConfirmDelete.MouseButton1Click:Connect(function()
	if deleteTarget and isfile(deleteTarget) then
		safeCall(delfile, deleteTarget)
		toast("Deleted", relName(deleteTarget) .. " removed.", C.DANGER)
	end
	closeDelete()
	task.defer(function()
		-- refresh happens after declaration below
	end)
end)

--==================================================
-- FILE CACHE
--==================================================
local FileCache = {}

local function refreshCache()
	FileCache = {}
	if isfolder(folderPath) then
		local files = listfiles(folderPath)
		table.sort(files, function(a, b)
			return relName(a):lower() < relName(b):lower()
		end)

		for _, path in ipairs(files) do
			local name = relName(path)
			FileCache[#FileCache + 1] = {
				path = path,
				name = name,
				size = fileBytes(path),
			}
		end
	end
	CountLabel.Text = tostring(#FileCache) .. " files"
end

--==================================================
-- ROW TEMPLATE
--==================================================
local function createRow(parent, file)
	local row = make("Frame", {
		Size = UDim2.new(1, -2, 0, 62),
		BackgroundColor3 = C.SURFACE,
		BorderSizePixel = 0,
		ZIndex = 10,
	}, parent)
	corner(row, 10)
	stroke(row, C.ACCENT, 1, 0.88)
	pad(row, 10, 10, 8, 8)

	local name = label(row, file.name, 14, C.TEXT, true)
	name.Position = UDim2.new(0, 0, 0, 0)
	name.Size = UDim2.new(1, -150, 0, 20)
	name.ZIndex = 12

	local meta = label(row, fmtBytes(file.size), 12, C.MUTED, false)
	meta.Position = UDim2.new(0, 0, 0, 24)
	meta.Size = UDim2.new(1, -150, 0, 16)
	meta.ZIndex = 12

	local run = button(row, "Run", C.ACCENT, Color3.new(1, 1, 1), 13)
	run.Size = UDim2.new(0, 58, 0, 34)
	run.Position = UDim2.new(1, -124, 0.5, -17)
	run.ZIndex = 20

	local del = button(row, "Del", C.DANGER, Color3.new(1, 1, 1), 13)
	del.Size = UDim2.new(0, 58, 0, 34)
	del.Position = UDim2.new(1, -60, 0.5, -17)
	del.ZIndex = 20

	run.MouseButton1Click:Connect(function()
		local ok, err = safeExec(file.path)
		if ok then
			toast("Running", file.name, C.SUCCESS)
		else
			toast("Error", tostring(err), C.DANGER)
		end
	end)

	del.MouseButton1Click:Connect(function()
		openDelete(file.path)
	end)

	return row
end

