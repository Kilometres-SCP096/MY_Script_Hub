--// CYBER-EXECUTIVE HUB v4
--// Custom UI, mobile friendly, per-file Run/Delete, search-only filtering, proper scroll

local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local function getRoot()
	if typeof(gethui) == "function" then
		local ok, hui = pcall(gethui)
		if ok and hui then
			return hui
		end
	end
	return CoreGui
end

local Root = getRoot()

local HUB_NAME = "CyberExec_UX4"
local folderPath = "My_Script_Hub/"

if not isfolder(folderPath) then
	makefolder(folderPath)
end

--==================================================
-- THEME
--==================================================
local C = {
	BG = Color3.fromRGB(10, 10, 10),
	PANEL = Color3.fromRGB(15, 15, 15),
	SURFACE = Color3.fromRGB(22, 22, 22),
	SURFACE2 = Color3.fromRGB(30, 30, 30),
	ACCENT = Color3.fromRGB(138, 43, 226),
	TEXT = Color3.fromRGB(240, 240, 240),
	MUTED = Color3.fromRGB(165, 165, 165),
	DANGER = Color3.fromRGB(220, 70, 70),
	SUCCESS = Color3.fromRGB(75, 200, 120),
}

--==================================================
-- CLEANUP
--==================================================
for _, old in ipairs(Root:GetChildren()) do
	if old.Name == HUB_NAME then
		old:Destroy()
	end
end

--==================================================
-- HELPERS
--==================================================
local function make(className, props, parent)
	local obj = Instance.new(className)
	if props then
		for k, v in pairs(props) do
			obj[k] = v
		end
	end
	obj.Parent = parent
	return obj
end

local function corner(parent, radius)
	return make("UICorner", { CornerRadius = UDim.new(0, radius or 8) }, parent)
end

local function stroke(parent, color, thickness, transparency)
	return make("UIStroke", {
		Color = color or C.ACCENT,
		Thickness = thickness or 1.5,
		Transparency = transparency or 0
	}, parent)
end

local function pad(parent, l, r, t, b)
	return make("UIPadding", {
		PaddingLeft = UDim.new(0, l or 0),
		PaddingRight = UDim.new(0, r or 0),
		PaddingTop = UDim.new(0, t or 0),
		PaddingBottom = UDim.new(0, b or 0),
	}, parent)
end

local function label(parent, text, size, color, bold)
	return make("TextLabel", {
		BackgroundTransparency = 1,
		Text = text or "",
		TextColor3 = color or C.TEXT,
		TextSize = size or 14,
		Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Center,
		TextWrapped = false,
		ClipsDescendants = true,
	}, parent)
end

local function button(parent, text, bg, fg, size)
	local b = make("TextButton", {
		Text = text or "",
		BackgroundColor3 = bg or C.SURFACE,
		TextColor3 = fg or C.TEXT,
		TextSize = size or 14,
		Font = Enum.Font.GothamSemibold,
		AutoButtonColor = true,
		BorderSizePixel = 0,
		ClipsDescendants = true,
	}, parent)
	corner(b, 8)
	stroke(b, C.ACCENT, 1, 0.85)
	return b
end

local function input(parent, placeholder, multiline, height)
	local t = make("TextBox", {
		Text = "",
		PlaceholderText = placeholder or "",
		ClearTextOnFocus = false,
		MultiLine = multiline or false,
		BackgroundColor3 = C.SURFACE2,
		TextColor3 = C.TEXT,
		PlaceholderColor3 = C.MUTED,
		TextSize = 14,
		Font = Enum.Font.Gotham,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = multiline and Enum.TextYAlignment.Top or Enum.TextYAlignment.Center,
	}, parent)
	corner(t, 8)
	stroke(t, C.ACCENT, 1, 0.88)
	pad(t, 10, 10, 8, 8)
	if height then
		t.Size = UDim2.new(1, 0, 0, height)
	end
	return t
end

local function relName(path)
	if typeof(path) ~= "string" then
		return ""
	end
	if path:sub(1, #folderPath) == folderPath then
		return path:sub(#folderPath + 1)
	end
	return path
end

local function ensureLuaName(name)
	name = tostring(name or ""):gsub("^%s+", ""):gsub("%s+$", "")
	if name == "" then
		return ""
	end
	if not name:lower():match("%.lua$") then
		name = name .. ".lua"
	end
	return name
end

local function safeExec(path)
	if not isfile(path) then
		return false, "File not found"
	end
	local ok, err = pcall(function()
		loadstring(readfile(path))()
	end)
	if not ok then
		return false, err
	end
	return true
end

local function fileBytes(path)
	local ok, data = pcall(readfile, path)
	if ok and type(data) == "string" then
		return #data
	end
	return 0
end

local function fmtBytes(n)
	n = tonumber(n) or 0
	if n < 1024 then
		return tostring(n) .. " B"
	elseif n < 1024 * 1024 then
		return string.format("%.1f KB", n / 1024)
	else
		return string.format("%.2f MB", n / (1024 * 1024))
	end
end

local function clearFrame(frame)
	for _, child in ipairs(frame:GetChildren()) do
		if not child:IsA("UIListLayout") and not child:IsA("UIPadding") and not child:IsA("UIStroke") and not child:IsA("UICorner") then
			child:Destroy()
		end
	end
end

local function findExactFile(query)
	query = tostring(query or ""):gsub("^%s+", ""):gsub("%s+$", "")
	if query == "" then
		return nil
	end

	local candidates = {
		folderPath .. query,
		folderPath .. ensureLuaName(query),
		query,
		ensureLuaName(query),
	}

	for _, p in ipairs(candidates) do
		if isfile(p) then
			return p
		end
	end

	local q = query:lower()
	for _, p in ipairs(listfiles(folderPath)) do
		local name = relName(p):lower()
		if name == q or name == ensureLuaName(q):lower() then
			return p
		end
	end

	return nil
end

