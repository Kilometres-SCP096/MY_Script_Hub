SavedSubtitle.TextColor3 = Theme.TextDim
SavedSubtitle.TextSize = 11
SavedSubtitle.TextXAlignment = "Left"

local SavedScroll = Instance.new("ScrollingFrame", SavedPage)
SavedScroll.Size = UDim2.new(1, 0, 1, -65)
SavedScroll.Position = UDim2.new(0, 0, 0, 60)
SavedScroll.BackgroundTransparency = 1
SavedScroll.BorderSizePixel = 0
