--// CYBER-EXECUTIVE HUB //--
--// High-UX mobile executor hub with per-script actions //--

--////////////////////////////////////////////////////
-- SERVICES / ROOT
--////////////////////////////////////////////////////
local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local function getRoot()
    if typeof(gethui) == "function" then
        local ok, hui = pcall(gethui)
        if ok and hui then
            return hui
        end
    end
    return CoreGui
end

local Root = getRoot()

--////////////////////////////////////////////////////
-- CONFIG
--////////////////////////////////////////////////////
local HUB_NAME = "CyberExec_Pro"
local folderPath = "My_Script_Hub/"
if not isfolder(folderPath) then
    makefolder(folderPath)
end

local C = {
    BG = Color3.fromRGB(10, 10, 10),
    PANEL = Color3.fromRGB(15, 15, 15),
    SURFACE = Color3.fromRGB(22, 22, 22),
    SURFACE_2 = Color3.fromRGB(30, 30, 30),
    ACCENT = Color3.fromRGB(138, 43, 226),
    TEXT = Color3.fromRGB(235, 235, 235),
    MUTED = Color3.fromRGB(170, 170, 170),
    DANGER = Color3.fromRGB(220, 70, 70),
    SUCCESS = Color3.fromRGB(80, 200, 130),
}

local function safeCall(fn, ...)
    local ok, res = pcall(fn, ...)
    if not ok then
        warn("[CyberExec] " .. tostring(res))
    end
    return ok, res
end

local function trim(s)
    s = tostring(s or "")
    return (s:gsub("^%s+", ""):gsub("%s+$", ""))
end

local function normalizeName(name)
    name = trim(name)
    if name == "" then return "" end
    return name
end

local function ensureLuaName(name)
    name = normalizeName(name)
    if name == "" then return "" end
    if not name:lower():match("%.lua$") then
        name = name .. ".lua"
    end
    return name
end

local function relName(path)
    return path:gsub("^" .. folderPath:gsub("(%p)", "%%%1"), "")
end

local function getDisplaySize(bytes)
    bytes = tonumber(bytes) or 0
    if bytes < 1024 then
        return tostring(bytes) .. " B"
    elseif bytes < 1024 * 1024 then
        return string.format("%.1f KB", bytes / 1024)
    else
        return string.format("%.2f MB", bytes / (1024 * 1024))
    end
end

local function getFileSize(path)
    local ok, content = pcall(readfile, path)
    if ok and type(content) == "string" then
        return #content
    end
    return 0
end

local function execFile(path)
    if not isfile(path) then
        return false, "File not found"
    end
    local ok, err = pcall(function()
        local src = readfile(path)
        loadstring(src)()
    end)
    if not ok then
        return false, err
    end
    return true
end

local function findExactFileByName(input)
    input = normalizeName(input)
    if input == "" then return nil end

    local directCandidates = {
        folderPath .. input,
        folderPath .. ensureLuaName(input),
        input,
        ensureLuaName(input),
    }

    for _, p in ipairs(directCandidates) do
        if isfile(p) then
            return p
        end
    end

    local target = input:lower()
    local files = listfiles(folderPath)
    for _, p in ipairs(files) do
        local name = relName(p)
        if name:lower() == target or name:lower() == ensureLuaName(target):lower() then
            return p
        end
    end

    return nil
end

--////////////////////////////////////////////////////
-- CLEANUP
--////////////////////////////////////////////////////
for _, old in ipairs(Root:GetChildren()) do
    if old.Name == HUB_NAME then
        old:Destroy()
    end
end

--////////////////////////////////////////////////////
