-- // PAGES // --
local Pages = {}
local function NewPage(name)
    local f = Instance.new("Frame", Container)
    f.Name = name
    f.Size = UDim2.new(1, 0, 1, 0)
    f.BackgroundTransparency = 1
    f.Visible = false
    Pages[name] = f
    return f
end

