-- ========================================
-- NAV BUTTONS
-- ========================================
local navBtns = {}

local function Nav(icon, page, ord, tip)
    local wrapper = Instance.new("Frame", NavCont)
    wrapper.Size = UDim2.new(0, 52, 0, 65)
    wrapper.BackgroundTransparency = 1
    wrapper.LayoutOrder = ord

    local b = IconBtn(wrapper, icon)
    b.Size = UDim2.new(0, 52, 0, 52)
    b.Position = UDim2.new(0, 0, 0, 0)

    local tipLbl = Instance.new("TextLabel", wrapper)
    tipLbl.Size = UDim2.new(1, 0, 0, 12)
    tipLbl.Position = UDim2.new(0, 0, 0, 53)
    tipLbl.BackgroundTransparency = 1
    tipLbl.Text = tip
    tipLbl.TextColor3 = Theme.TextDim
    tipLbl.Font = Enum.Font.Gotham
    tipLbl.TextSize = 9

    b.MouseButton1Click:Connect(function()
        Switch(page)
        for _, n in pairs(navBtns) do
            Tween(n, "BackgroundColor3", Theme.Surface)
        end
        Tween(b, "BackgroundColor3", Theme.Primary)
        tipLbl.TextColor3 = Theme.Accent
        for _, other in pairs(NavCont:GetChildren()) do
            if other:IsA("Frame") and other ~= wrapper then
                local otherTip = other:FindFirstChildWhichIsA("TextLabel")
                if otherTip then otherTip.TextColor3 = Theme.TextDim end
            end
        end
    end)

    table.insert(navBtns, b)
    return b
end

local n1 = Nav("rbxassetid://6031154871", "Search", 1, "Search")
local n2 = Nav("rbxassetid://6035043449", "Add", 2, "Add")
local n3 = Nav("rbxassetid://6034823313", "Runner", 3, "Runner")
local n4 = Nav("rbxassetid://6031155054", "Saved", 4, "Saved")
local n5 = Nav("rbxassetid://6031225819", "Settings", 5, "Settings")

-- ========================================
-- STARTUP
-- ========================================
Switch("Runner")
Refresh()
DoSearch("")

-- Highlight runner nav on start
Tween(n3, "BackgroundColor3", Theme.Primary)

print("✅ Cyber-Neo Hub v8.0 FIXED - Loaded Successfully!")
